---
import Button from '../primitives/Button.astro';

interface Props {
  date?: string;
  duration?: string;
  format?: string;
  price?: string;
  seats?: string;
}

const {
  date = 'Saturday, June 27',
  duration = '90 minutes',
  format = 'live online',
  price = '$197',
  seats = 'Limited to 30 seats per cohort to keep correction quality high.',
} = Astro.props;
---

<div class="bg-cream border border-rule p-10 md:p-16 text-center max-w-[540px] mx-auto">
  <p
    class="text-muted uppercase tracking-widest mb-8"
    style="font-size: var(--font-size-small);"
  >
    {date} · {duration} · {format}
  </p>
  <p
    class="text-navy font-bold leading-none mb-10"
    style="font-size: clamp(3rem, 8vw, 4.5rem);"
  >
    {price}
  </p>
  <Button href="#" variant="primary">Reserve your seat</Button>
  <p
    class="text-muted mt-8 m-0"
    style="font-size: var(--font-size-small);"
  >
    {seats}
  </p>
</div>

---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
}

const { href, label, variant = 'secondary' } = Astro.props;

const base = 'inline-flex items-center justify-center font-semibold transition-all duration-200 cursor-pointer no-underline text-small tracking-wide';

const styles: Record<string, string> = {
  primary:   'bg-terracotta text-white px-8 py-3.5 hover:opacity-90 active:opacity-80',
  secondary: 'border border-navy text-navy px-8 py-3.5 hover:bg-navy hover:text-white',
};
---

<a
  href={href}
  class={`${base} ${styles[variant]}`}
  target="_blank"
  rel="noopener noreferrer"
>
  {label}
</a>

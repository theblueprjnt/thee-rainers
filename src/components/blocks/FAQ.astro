---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-rule">
  {items.map((item) => (
    <details class="group py-6">
      <summary
        class="flex items-center justify-between gap-6 cursor-pointer text-navy font-semibold"
        style="font-size: var(--font-size-h3); line-height: 1.3; list-style: none;"
      >
        <span>{item.question}</span>
        <span
          class="flex-shrink-0 text-muted transition-transform duration-200 group-open:rotate-45"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 3v12M3 9h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
      </summary>
      <p
        class="mt-5 text-muted leading-[1.55] max-w-[600px]"
        style="font-size: var(--font-size-body);"
      >
        {item.answer}
      </p>
    </details>
  ))}
</div>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>

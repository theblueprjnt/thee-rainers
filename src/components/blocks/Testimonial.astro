---
interface Props {
  quote: string;
  name: string;
  location: string;
  imageSrc?: string;
}

const { quote, name, location, imageSrc } = Astro.props;
---

<figure class="flex flex-col gap-6 m-0">
  {imageSrc ? (
    <img
      src={imageSrc}
      alt={name}
      width="64"
      height="64"
      class="w-16 h-16 rounded-full object-cover"
    />
  ) : (
    <div class="w-16 h-16 rounded-full bg-rule flex items-center justify-center flex-shrink-0" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <circle cx="11" cy="7.5" r="3.5" fill="#d9d4cc"/>
        <path d="M3.5 19c0-4.1 3.4-7 7.5-7s7.5 2.9 7.5 7" stroke="#d9d4cc" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </div>
  )}
  <blockquote class="m-0 flex-1">
    <p class="text-ink leading-[1.65] m-0" style="font-size: var(--font-size-body);">
      <span class="font-serif italic">"{quote}"</span>
    </p>
  </blockquote>
  <figcaption class="flex flex-col gap-0.5">
    <span class="font-semibold text-navy" style="font-size: var(--font-size-small);">{name}</span>
    <span class="text-muted" style="font-size: var(--font-size-small);">{location}</span>
  </figcaption>
</figure>

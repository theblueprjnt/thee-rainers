---
const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-[#0A0A0A]/8">
  <div class="max-w-[1140px] mx-auto px-6 py-10 flex flex-col gap-8">

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <a href="/" class="flex items-center">
        <img src="/images/logo-trb.png" alt="Thee Rainers" class="h-10 w-auto opacity-60 hover:opacity-100 transition-opacity duration-200" />
      </a>
      <div class="flex items-center gap-5 flex-wrap">
        <a href="https://www.instagram.com/theerainers" target="_blank" rel="noopener" class="text-[10px] text-[#0A0A0A]/35 tracking-widest uppercase hover:text-[#0A0A0A] transition-colors duration-200">Instagram</a>
        <a href="https://www.tiktok.com/@theerainers" target="_blank" rel="noopener" class="text-[10px] text-[#0A0A0A]/35 tracking-widest uppercase hover:text-[#0A0A0A] transition-colors duration-200">TikTok</a>
        <a href="https://www.facebook.com/theerainers" target="_blank" rel="noopener" class="text-[10px] text-[#0A0A0A]/35 tracking-widest uppercase hover:text-[#0A0A0A] transition-colors duration-200">Facebook</a>
        <a href="https://www.youtube.com/@Rainers" target="_blank" rel="noopener" class="text-[10px] text-[#0A0A0A]/35 tracking-widest uppercase hover:text-[#0A0A0A] transition-colors duration-200">YouTube</a>
        <a href="https://www.threads.net/@theerainers" target="_blank" rel="noopener" class="text-[10px] text-[#0A0A0A]/35 tracking-widest uppercase hover:text-[#0A0A0A] transition-colors duration-200">Threads</a>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-6 border-t border-[#0A0A0A]/8">
      <div class="flex items-center gap-5 flex-wrap">
        <a href="/qa" class="text-[10px] text-[#0A0A0A]/25 hover:text-[#0A0A0A]/60 transition-colors duration-200 tracking-wide">Q&A</a>
        <a href="/lever-audit" class="text-[10px] text-[#0A0A0A]/25 hover:text-[#0A0A0A]/60 transition-colors duration-200 tracking-wide">7-Lever Audit</a>
        <a href="/footwork-foundation" class="text-[10px] text-[#0A0A0A]/25 hover:text-[#0A0A0A]/60 transition-colors duration-200 tracking-wide">Free Foundation</a>
        <a href="/about" class="text-[10px] text-[#0A0A0A]/25 hover:text-[#0A0A0A]/60 transition-colors duration-200 tracking-wide">About</a>
        <a href="/command" class="text-[10px] tracking-wide transition-opacity duration-200 hover:opacity-70"
          style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          Private Architecture
        </a>
        <a href="/links" class="text-[10px] text-[#0A0A0A]/25 hover:text-[#0A0A0A]/60 transition-colors duration-200 tracking-wide">All Links</a>
      </div>
      <span class="text-[10px] text-[#0A0A0A]/15 tracking-wide">© {year} Thee Rainers · theerainers.com</span>
    </div>

  </div>
</footer>

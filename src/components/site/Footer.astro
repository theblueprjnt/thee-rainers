---
const year = new Date().getFullYear();
---

<footer class="bg-[#0A0A0A] border-t border-white/5">
  <div class="max-w-[1140px] mx-auto px-6 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
    <a href="/" class="flex items-center">
      <img src="/images/logo-trb.png" alt="Thee Rainers" class="h-8 w-auto opacity-70 hover:opacity-100 transition-opacity duration-200" />
    </a>
    <div class="flex items-center gap-6 flex-wrap">
      <a href="/qa" class="text-xs text-white/30 hover:text-white/60 transition-colors duration-200">Q&A</a>
      <a href="/feedback" class="text-xs text-white/30 hover:text-white/60 transition-colors duration-200">Feedback</a>
      <a href="/lever-audit" class="text-xs text-white/30 hover:text-white/60 transition-colors duration-200">7-Lever Audit</a>
      <a href="/privacy" class="text-xs text-white/30 hover:text-white/60 transition-colors duration-200">Privacy</a>
      <a href="/terms" class="text-xs text-white/30 hover:text-white/60 transition-colors duration-200">Terms</a>
      <span class="text-xs text-white/15">© {year} Thee Rainers</span>
    </div>
  </div>
</footer>

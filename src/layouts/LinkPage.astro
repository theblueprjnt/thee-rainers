---
import Analytics from '../components/greatness/Analytics.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  noindex?: boolean;
}

const { title = 'Thee Rainers — Links', noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://theerainers.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Thee Rainers — Engineered for the ring. Free protocol, live workshop, Private Architecture." />
    <meta property="og:title" content="Thee Rainers — Links" />
    <meta property="og:url" content={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}
    <title>{title}</title>
    <Analytics />
  </head>
  <body class="bg-white text-[#0A0A0A] min-h-screen">
    <slot />
  </body>
</html>

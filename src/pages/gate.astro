---
import Layout from '../layouts/Base.astro';
---
<Layout title="Enter — Thee Rainers">
  <Fragment slot="head">
    <meta name="description" content="One question. Two paths. The entry point to the system." />
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="w-full h-screen bg-white flex flex-col items-center justify-center px-8 text-center">

    <!-- Question state -->
    <div id="gate-question" class="flex flex-col items-center">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-10">Before you continue.</p>
      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-[3.5rem] leading-[0.85] mb-16 max-w-[680px]">
        Are you building<br/>a system — or trying<br/>to get fit?
      </h1>
      <div class="flex flex-col sm:flex-row gap-4">
        <button id="btn-system"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 cursor-pointer hover:bg-[#0057FF] hover:text-white">
          I'm building a system.
        </button>
        <button id="btn-fit"
          class="inline-flex items-center justify-center font-bold border-2 border-[#0A0A0A]/15 text-[#0A0A0A]/25 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 cursor-pointer hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/40">
          I'm looking to get fit.
        </button>
      </div>
    </div>

    <!-- Rejection state -->
    <div id="gate-rejection" style="display:none" class="flex flex-col items-center">
      <p class="text-[#0A0A0A]/30 text-[11px] tracking-widest uppercase mb-10">Understood.</p>
      <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-[3.5rem] leading-[0.85] mb-8 max-w-[560px]">
        This program<br/>isn't built for that.
      </h2>
      <p class="text-[#0A0A0A]/40 text-base max-w-[380px] leading-relaxed mb-10">
        The Footwork Foundation is free. Start there. Come back when the question changes.
      </p>
      <a href="/footwork-foundation"
        class="inline-flex items-center gap-2 text-[#D4A373] text-sm font-bold tracking-widest uppercase hover:opacity-60 transition-opacity duration-200">
        The Footwork Foundation →
      </a>
    </div>

  </section>

  <script>
    const question = document.getElementById('gate-question')!;
    const rejection = document.getElementById('gate-rejection')!;

    document.getElementById('btn-system')?.addEventListener('click', () => {
      window.location.href = '/vault';
    });

    document.getElementById('btn-fit')?.addEventListener('click', () => {
      question.style.transition = 'opacity 0.25s ease';
      question.style.opacity = '0';
      setTimeout(() => {
        question.style.display = 'none';
        rejection.style.display = 'flex';
        rejection.style.flexDirection = 'column';
        rejection.style.alignItems = 'center';
        rejection.style.opacity = '0';
        rejection.style.transition = 'opacity 0.35s ease';
        requestAnimationFrame(() => { rejection.style.opacity = '1'; });
      }, 250);
    });
  </script>
</Layout>

---
import LinkPage from '../layouts/LinkPage.astro';
---
<LinkPage title="7-Lever Audit — Thee Rainers">

<div id="quiz" class="min-h-screen bg-white flex flex-col">

  <!-- Progress bar -->
  <div id="progress-rail" class="hidden fixed top-0 left-0 right-0 h-[2px] bg-[#0A0A0A]/8 z-50">
    <div id="progress-fill" class="h-full bg-[#0057FF] transition-all duration-400" style="width:0%"></div>
  </div>

  <!-- ── INTRO ── -->
  <div id="s-intro" class="screen flex flex-col items-center justify-center px-6 py-20 text-center min-h-screen">
    <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-6">Thee Rainers · For Competitors</p>
    <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-5xl md:text-6xl leading-[0.85] mb-6">
      7-Lever<br/>Audit
    </h1>
    <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-12 max-w-[280px]">
      Seven questions. Find your primary constraint before the next fight.
    </p>
    <button id="btn-start"
      class="inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-12 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
      Start →
    </button>
    <p class="text-[#0A0A0A]/20 text-[10px] tracking-widest uppercase mt-8">Rate yourself as the sparring version — not the drilling version</p>
  </div>

  <!-- ── LEVERS 0–6 (generated by JS) ── -->
  <div id="s-levers" class="screen hidden flex-col items-center justify-center px-6 py-20 min-h-screen">
    <p id="lev-progress" class="text-[#0A0A0A]/25 text-[10px] tracking-widest uppercase mb-12">1 of 7</p>
    <p id="lev-num" class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">01</p>
    <h2 id="lev-name" class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.85] mb-8 text-center max-w-[480px]">Cue Reading</h2>
    <p id="lev-question" class="text-[#0A0A0A]/40 text-base leading-relaxed mb-12 text-center max-w-[360px] italic">
      Question text
    </p>
    <div id="lev-ratings" class="flex gap-2 w-full max-w-[360px]">
      <!-- 1–5 buttons rendered here -->
    </div>
    <div class="flex justify-between w-full max-w-[360px] mt-3">
      <span class="text-[10px] text-[#0A0A0A]/20 tracking-wide uppercase">Breaks consistently</span>
      <span class="text-[10px] text-[#0A0A0A]/20 tracking-wide uppercase">Automatic</span>
    </div>
  </div>

  <!-- ── EMAIL GATE ── -->
  <div id="s-email" class="screen hidden flex-col items-center justify-center px-6 py-20 text-center min-h-screen">
    <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-6">Audit complete</p>
    <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl leading-[0.85] mb-6">
      Results<br/>are ready.
    </h2>
    <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-10 max-w-[280px]">
      Enter your email to see your score and download the full PDF.
    </p>
    <form id="email-form" class="flex flex-col gap-3 w-full max-w-[320px]">
      <input type="email" id="gate-email" required placeholder="your@email.com"
        class="border border-[#0A0A0A]/15 bg-transparent px-5 py-4 text-[#0A0A0A] text-sm focus:border-[#0057FF] focus:outline-none transition-colors duration-200 placeholder:text-[#0A0A0A]/20 text-center" />
      <button type="submit" id="btn-results"
        class="inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
        See My Results →
      </button>
    </form>
    <p class="text-[#0A0A0A]/15 text-[10px] tracking-wide mt-6">PDF downloads automatically.</p>
  </div>

  <!-- ── RESULTS ── -->
  <div id="s-results" class="screen hidden flex-col items-center px-6 py-20 min-h-screen">
    <div class="w-full max-w-[420px]">

      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-8 text-center">Your Audit Results</p>

      <!-- Score -->
      <div class="flex items-baseline gap-3 mb-2 justify-center">
        <span id="res-total" class="font-black text-[#0A0A0A] text-7xl leading-none tracking-tighter">—</span>
        <span class="text-[#0A0A0A]/20 text-2xl font-black">/35</span>
      </div>
      <p id="res-verdict" class="text-[#0A0A0A]/40 text-sm tracking-wide text-center mb-10">—</p>

      <!-- Primary constraint -->
      <div class="border-l-2 border-[#D4A373] pl-5 mb-10">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">Primary Constraint</p>
        <p id="res-constraint" class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl">—</p>
        <p id="res-constraint-note" class="text-[#0A0A0A]/40 text-xs leading-relaxed mt-1">Address this lever first. Every other improvement compounds on it.</p>
      </div>

      <!-- Lever bars -->
      <div id="res-bars" class="flex flex-col gap-2 mb-10"></div>

      <!-- CTA -->
      <a id="res-cta" href="/"
        class="w-full inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white mb-4">
        —
      </a>
      <a href="/lever-audit"
        class="block text-center text-[10px] text-[#0A0A0A]/25 tracking-widest uppercase hover:text-[#0A0A0A]/50 transition-colors duration-200">
        Download PDF again →
      </a>

      <!-- PA visibility -->
      <div class="border border-[#6A0DAD]/15 p-5 mt-8">
        <p class="text-[#6A0DAD] text-[10px] tracking-widest uppercase mb-1">Application Only</p>
        <p class="text-[#0A0A0A]/50 text-xs leading-relaxed mb-3">Private Architecture deploys all seven levers as one system — built around your specific structure.</p>
        <a href="/command" class="text-[#6A0DAD]/70 text-[10px] tracking-widest uppercase hover:text-[#6A0DAD] transition-colors duration-200">See Private Architecture →</a>
      </div>

      <!-- Scripture -->
      <p class="text-[#0A0A0A]/10 text-[10px] tracking-widest uppercase text-center mt-12">1 Corinthians 9:26–27</p>
    </div>
  </div>

</div>

<style>
  .screen { display: none; }
  .screen.flex-col { display: none; }
  .screen.active { display: flex !important; }

  .rating-btn {
    flex: 1;
    aspect-ratio: 1;
    border: 1px solid rgba(10,10,10,0.12);
    background: transparent;
    font-family: inherit;
    font-weight: 800;
    font-size: 1.1rem;
    color: rgba(10,10,10,0.4);
    cursor: pointer;
    transition: all 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
  }

  .rating-btn:hover { border-color: #0057FF; color: #0057FF; }
  .rating-btn.selected { background: #0057FF; border-color: #0057FF; color: #fff; }

  .lever-bar {
    display: grid;
    grid-template-columns: 110px 1fr 24px;
    align-items: center;
    gap: 8px;
  }

  .lever-bar.is-primary .lbr-label { color: #D4A373; font-weight: 800; }
  .lever-bar.is-primary .lbr-fill { background: #D4A373; }

  .lbr-label {
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(10,10,10,0.4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lbr-track {
    height: 3px;
    background: rgba(10,10,10,0.08);
    border-radius: 2px;
    overflow: hidden;
  }

  .lbr-fill {
    height: 100%;
    background: #0A0A0A;
    border-radius: 2px;
    transition: width 0.6s cubic-bezier(0.16,1,0.3,1);
  }

  .lbr-score {
    font-size: 11px;
    font-weight: 800;
    color: rgba(10,10,10,0.3);
    text-align: right;
  }
</style>

<script>
  const LEVERS = [
    { num: '01', name: 'Cue Reading',               q: 'In sparring — do you see punches arriving, or feel them landing?' },
    { num: '02', name: 'Kinetic Chain',              q: 'Do your punches come from your legs and hip — or your shoulder and arm?' },
    { num: '03', name: 'Reactive Stiffness',         q: 'Does your footwork feel springy by round 4 — or flat and heavy?' },
    { num: '04', name: 'Range Fluency',              q: 'Can you generate offence at all three ranges — or do you have one home?' },
    { num: '05', name: 'Defensive Responsibility',   q: 'When you throw combinations — does your guard hold, or does your chin get exposed?' },
    { num: '06', name: 'Transfer to Live',           q: 'Is your sparring the same standard as your pad work — or does pressure strip the technique?' },
    { num: '07', name: 'Identity & Presence',        q: "When hurt and behind — do you fight your system, or contract and wait for the round to end?" },
  ];

  const ROUTES: Record<string, {verdict: string; url: string; cta: string}> = {
    foundation: { verdict: 'The base layer needs work before the system can compound.',        url: '/footwork-foundation', cta: 'Start the 30-Day Protocol →' },
    workshop:   { verdict: 'The mechanics are there. One session locks them into structure.',  url: '/workshop',            cta: 'Reserve Your Workshop Seat →' },
    command:    { verdict: 'Your system is close. One lever is capping everything above it.', url: '/command',             cta: 'Apply for Private Architecture →' },
  };

  const answers: number[] = new Array(7).fill(0);
  let current = 0;

  function show(id: string) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const el = document.getElementById(id);
    if (el) el.classList.add('active');
  }

  function setProgress(done: number) {
    const rail = document.getElementById('progress-rail');
    const fill = document.getElementById('progress-fill');
    if (done > 0) rail?.classList.remove('hidden');
    if (fill) fill.style.width = `${(done / 7) * 100}%`;
  }

  function renderLever(i: number) {
    const l = LEVERS[i];
    const numEl = document.getElementById('lev-num');
    const nameEl = document.getElementById('lev-name');
    const qEl = document.getElementById('lev-question');
    const progEl = document.getElementById('lev-progress');
    const ratingsEl = document.getElementById('lev-ratings');

    if (numEl) numEl.textContent = l.num;
    if (nameEl) nameEl.textContent = l.name;
    if (qEl) qEl.textContent = l.q;
    if (progEl) progEl.textContent = `${i + 1} of 7`;

    if (ratingsEl) {
      ratingsEl.innerHTML = [1,2,3,4,5].map(v => `
        <button class="rating-btn${answers[i] === v ? ' selected' : ''}" data-lever="${i}" data-val="${v}">
          ${v}
        </button>
      `).join('');
    }

    setProgress(i);
    show('s-levers');

    // Bind clicks
    ratingsEl?.querySelectorAll('.rating-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const lever = parseInt((btn as HTMLElement).dataset.lever ?? '0');
        const val = parseInt((btn as HTMLElement).dataset.val ?? '1');
        answers[lever] = val;
        ratingsEl.querySelectorAll('.rating-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        setTimeout(() => {
          if (lever < 6) {
            current = lever + 1;
            renderLever(current);
          } else {
            setProgress(7);
            show('s-email');
          }
        }, 220);
      });
    });
  }

  function showResults() {
    const total = answers.reduce((a, b) => a + b, 0);
    const minVal = Math.min(...answers);
    const minIdx = answers.indexOf(minVal);

    const route = total <= 16 ? ROUTES.foundation
                : total <= 27 ? ROUTES.workshop
                : ROUTES.command;

    const totalEl = document.getElementById('res-total');
    const verdictEl = document.getElementById('res-verdict');
    const constraintEl = document.getElementById('res-constraint');
    const ctaEl = document.getElementById('res-cta') as HTMLAnchorElement | null;
    const barsEl = document.getElementById('res-bars');

    if (totalEl) totalEl.textContent = String(total);
    if (verdictEl) verdictEl.textContent = route.verdict;
    if (constraintEl) constraintEl.textContent = LEVERS[minIdx].name;
    if (ctaEl) { ctaEl.textContent = route.cta; ctaEl.href = route.url; }

    if (barsEl) {
      barsEl.innerHTML = LEVERS.map((l, i) => `
        <div class="lever-bar${i === minIdx ? ' is-primary' : ''}">
          <span class="lbr-label">${l.num} ${l.name}</span>
          <div class="lbr-track"><div class="lbr-fill" style="width:${(answers[i]/5)*100}%"></div></div>
          <span class="lbr-score">${answers[i]}</span>
        </div>
      `).join('');
    }

    show('s-results');

    // Trigger PDF download
    const a = document.createElement('a');
    a.href = '/pdfs/lever-audit.pdf';
    a.download = '7-Lever-Audit-Thee-Rainers.pdf';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  // Boot — show intro screen immediately
  show('s-intro');

  document.getElementById('btn-start')?.addEventListener('click', () => {
    current = 0;
    renderLever(0);
  });

  document.getElementById('email-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-results') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Loading...'; }

    const email = (document.getElementById('gate-email') as HTMLInputElement)?.value.trim();

    try {
      await fetch('/api/lead-capture', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'lever-audit-quiz', full_name: '' }),
      });
    } catch {
      // Non-blocking — show results regardless
    }

    showResults();
  });
</script>

</LinkPage>

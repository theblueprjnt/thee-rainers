---
import LinkPage from '../layouts/LinkPage.astro';
---
<LinkPage title="Thee Rainers — Links">

  <div class="max-w-[440px] mx-auto px-6 py-14 flex flex-col items-center gap-10">

    <!-- Identity -->
    <div class="flex flex-col items-center gap-3 text-center">
      <a href="/">
        <img src="/images/logo-trb.png" alt="Thee Rainers" class="h-10 w-auto" />
      </a>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Systemic Boxing Performance</p>
      <p class="text-[#0A0A0A]/40 text-sm leading-relaxed max-w-[300px]">Engineered for the ring. Seven levers. One operating system. Built for fighters who think in structures.</p>
    </div>

    <!-- Links stack -->
    <div class="w-full flex flex-col gap-3">

      <!-- 1. Free Protocol — top of funnel, highest volume -->
      <a href="/footwork-foundation"
        class="w-full flex items-center justify-between border-2 border-[#0057FF] text-[#0057FF] px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white group">
        <span>Free 30-Day Protocol</span>
        <span class="text-xs opacity-60 group-hover:opacity-100">Footwork Foundation →</span>
      </a>

      <!-- 2. YouTube subscribe — channel growth priority -->
      <a href="https://www.youtube.com/@Rainers?sub_confirmation=1"
        target="_blank" rel="noopener"
        class="w-full flex items-center justify-between border-2 border-[#0057FF] text-[#0057FF] px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white group">
        <span>Subscribe on YouTube</span>
        <span class="text-xs opacity-60 group-hover:opacity-100">@Rainers →</span>
      </a>

      <!-- 3. Workshop — urgency, revenue -->
      <a href="/workshop"
        class="w-full flex items-center justify-between border border-[#0A0A0A]/12 text-[#0A0A0A]/70 px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:border-[#0057FF] hover:text-[#0057FF] group">
        <span>The Calibration Workshop</span>
        <span class="text-[#D4A373] text-xs tracking-widest">$197 · June 27 →</span>
      </a>

      <!-- 3b. Workshop Replay -->
      <a href="/workshop-replay"
        class="w-full flex items-center justify-between border border-[#0A0A0A]/12 text-[#0A0A0A]/70 px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:border-[#0057FF] hover:text-[#0057FF] group">
        <span>Workshop Replay</span>
        <span class="text-[#D4A373] text-xs tracking-widest">$47 · On Demand →</span>
      </a>

      <!-- 4. Latest video — drives watch time + subscribers -->
      <a href="https://youtu.be/SrFywBFkmik"
        target="_blank" rel="noopener"
        class="w-full flex items-center justify-between border border-[#0A0A0A]/12 text-[#0A0A0A]/70 px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A] group">
        <span>Latest Video</span>
        <span class="text-xs opacity-40 group-hover:opacity-70">What Boxing Does to Your Body →</span>
      </a>

      <!-- 5. 7-Lever Audit — competitor qualifier -->
      <a href="/lever-audit"
        class="w-full flex items-center justify-between border border-[#0A0A0A]/12 text-[#0A0A0A]/70 px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A] group">
        <span>Free 7-Lever Audit</span>
        <span class="text-xs opacity-40 group-hover:opacity-70">Find the leak →</span>
      </a>

      <!-- Divider -->
      <div class="border-t border-[#0A0A0A]/8 my-1"></div>

      <!-- 6. Social platforms — follow loop -->
      <div class="grid grid-cols-2 gap-3">
        <a href="https://www.instagram.com/theerainers" target="_blank" rel="noopener"
          class="flex items-center justify-between border border-[#0A0A0A]/10 px-4 py-3 text-[10px] text-[#0A0A0A]/40 tracking-widest uppercase hover:text-[#0A0A0A] hover:border-[#0A0A0A]/25 transition-all duration-200">
          <span>Instagram</span>
          <span class="opacity-50">331K</span>
        </a>
        <a href="https://www.tiktok.com/@theerainers" target="_blank" rel="noopener"
          class="flex items-center justify-between border border-[#0A0A0A]/10 px-4 py-3 text-[10px] text-[#0A0A0A]/40 tracking-widest uppercase hover:text-[#0A0A0A] hover:border-[#0A0A0A]/25 transition-all duration-200">
          <span>TikTok</span>
          <span class="opacity-50">90K</span>
        </a>
        <a href="https://www.facebook.com/theerainers" target="_blank" rel="noopener"
          class="flex items-center justify-between border border-[#0A0A0A]/10 px-4 py-3 text-[10px] text-[#0A0A0A]/40 tracking-widest uppercase hover:text-[#0A0A0A] hover:border-[#0A0A0A]/25 transition-all duration-200">
          <span>Facebook</span>
          <span class="opacity-50">110K</span>
        </a>
        <a href="https://www.threads.net/@theerainers" target="_blank" rel="noopener"
          class="flex items-center justify-between border border-[#0A0A0A]/10 px-4 py-3 text-[10px] text-[#0A0A0A]/40 tracking-widest uppercase hover:text-[#0A0A0A] hover:border-[#0A0A0A]/25 transition-all duration-200">
          <span>Threads</span>
          <span class="opacity-50">20K</span>
        </a>
      </div>

      <!-- Divider -->
      <div class="border-t border-[#0A0A0A]/8 my-1"></div>

      <!-- 7. Private Architecture — bottom, highest intent -->
      <a href="/command"
        class="w-full flex items-center justify-between border-2 border-[#6A0DAD] text-[#6A0DAD] px-6 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-200 hover:bg-[#6A0DAD] hover:text-white group">
        <span>Private Architecture</span>
        <span class="text-xs opacity-60 group-hover:opacity-100">Application Only →</span>
      </a>

    </div>

    <!-- Scripture anchor -->
    <p class="text-[#0A0A0A]/15 text-[10px] tracking-widest uppercase text-center mt-4">
      1 Corinthians 9:26–27
    </p>

  </div>

</LinkPage>

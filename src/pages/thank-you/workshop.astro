---
import Layout from '../../layouts/Base.astro';
---
<!-- TODO: POST-JUNE-27 DATE SWAP — update page title, h1, and all date references below -->
<Layout title="Seat Reserved — June 27 | Thee Rainers">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="bg-white px-8 md:px-16 lg:px-24 pt-32 pb-20">
    <div class="max-w-[720px] mx-auto w-full">

      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">Confirmed</p>
      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.85] mb-6">
        You're in.<br/>June 27.
      </h1>
      <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-12 max-w-[440px]">
        The Zoom link comes to your email 24 hours before the session. Camera on. Come ready to move.
      </p>

      <div class="border border-[#0A0A0A]/8 p-8 mb-12">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-6">Session details</p>
        <div class="flex flex-col divide-y divide-[#0A0A0A]/8">
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Date</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Saturday, June 27</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Format</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Live on Zoom · Camera on</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Length</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">90 minutes</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Zoom link</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Sent to your email 24h before</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Recording</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Delivered within 24h after</span>
          </div>
        </div>
      </div>

      <!-- NEXT STEP -->
      <div class="border-l-2 border-[#0057FF] pl-6 mb-12">
        <p class="text-[#0A0A0A]/30 text-[10px] tracking-widest uppercase mb-2">Do this now</p>
        <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-3">Know your primary constraint before you arrive.</p>
        <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-6 max-w-[400px]">
          The 7-lever audit identifies the specific lever holding your system back. 3 minutes. The people who arrive with this already scored get the most out of the live Q&A.
        </p>
        <a href="/lever-audit-quiz"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
          Take the 7-Lever Audit →
        </a>
      </div>

      <!-- WATCH THE PREVIOUS SESSION -->
      <div class="border border-[#0A0A0A]/8 p-8">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Optional — watch before June 27</p>
        <p class="text-[#0A0A0A]/60 text-sm font-bold mb-2">The previous workshop replay</p>
        <p class="text-[#0A0A0A]/35 text-xs leading-relaxed mb-5">Same mechanical foundations covered in this session. Watching it first means June 27 becomes refinement, not introduction.</p>
        <a href="/workshop-replay"
          class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/15 text-[#0A0A0A]/35 bg-transparent px-6 py-3 text-xs tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/60">
          Get the Replay — $79 →
        </a>
      </div>

    </div>
  </section>
</Layout>

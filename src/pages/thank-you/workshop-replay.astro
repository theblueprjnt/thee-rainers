---
import Layout from '../../layouts/Base.astro';
---
<Layout title="Check Your Email — Thee Rainers">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
    <meta name="description" content="Your Workshop Replay access link is on its way." />
  </Fragment>

  <section class="bg-white px-8 md:px-16 lg:px-24 pt-32 pb-20">
    <div class="max-w-[720px] mx-auto w-full">

      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">Purchase confirmed</p>
      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.85] mb-6">
        Check your<br/>email.
      </h1>
      <p class="text-[#0A0A0A]/50 text-base leading-relaxed mb-12 max-w-[440px]">
        Your access link is on its way. It arrives within a few minutes — click it to watch the full 90-minute session.
      </p>

      <div class="border border-[#0A0A0A]/8 p-8 mb-12">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-6">What to expect</p>
        <div class="flex flex-col divide-y divide-[#0A0A0A]/8">
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Delivery</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Email — arrives within minutes</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Access window</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">7 days from purchase</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">Content</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">90 min · Defense Workshop</span>
          </div>
          <div class="flex justify-between py-3">
            <span class="text-[#0A0A0A]/35 text-sm">No email?</span>
            <span class="text-[#0A0A0A]/70 text-sm font-bold">Check spam · rainers@theerainers.com</span>
          </div>
        </div>
      </div>

      <!-- Use the wait productively -->
      <div class="border-l-2 border-[#0057FF] pl-6 mb-12">
        <p class="text-[#0A0A0A]/30 text-[10px] tracking-widest uppercase mb-2">While you wait</p>
        <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-3">Know your primary constraint before you watch.</p>
        <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-6 max-w-[400px]">The 7-lever audit identifies the specific lever holding your system back. 3 minutes. You will get more out of the replay when you know what to look for.</p>
        <a href="/lever-audit-quiz"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
          Take the 7-Lever Audit →
        </a>
      </div>

    </div>
  </section>

  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-20">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] text-white/50 text-2xl md:text-3xl mb-4">
        "I do not box as one beating the air."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26</p>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Base.astro';
---
<Layout title="About — Thee Rainers">
  <Fragment slot="head">
    <meta name="description" content="Thee Rainers is the operating system built from the floor up — from film, data, and the body itself. For athletes whose ambition has outpaced their gym." />
  </Fragment>

  <!-- Identity -->
  <section class="bg-white min-h-screen px-8 md:px-16 lg:px-24 pt-32 md:pt-40 pb-24">
    <div class="max-w-[1280px] mx-auto w-full">

      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-16 md:gap-24 mb-24">
        <div>
          <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-8">The Identity</p>
          <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-5xl md:text-7xl leading-[0.82] mb-10">Not a brand.<br/>A standard.</h1>
          <p class="text-[#0A0A0A]/50 text-base leading-relaxed max-w-[480px] mb-8">
              Thee Rainers is the operating system I built because the gym gave me fragments. No structure, no sequence, no source. I had to build it from the floor up — from the Word, from the film, from the data my own body gave me.
          </p>
          <p class="text-[#0A0A0A]/30 text-sm leading-relaxed max-w-[480px]">
            The mission is not to produce fighters. It is to produce people who think, move, and operate with systemic precision — and give the glory back to God when they do.
          </p>
        </div>
        <div class="hidden md:flex flex-col items-center gap-4">
          <div class="w-full max-w-[280px] aspect-[3/4] overflow-hidden border border-[#0A0A0A]/8">
            <img
              src="/images/aikido-yellowbelt.png"
              alt="The foundation started early."
              class="w-full h-full object-cover object-top"
            />
          </div>
          <p class="text-[#0A0A0A]/20 text-[10px] tracking-widest uppercase text-center">The foundation started early.</p>
        </div>
      </div>

      <!-- The Ecosystem -->
      <div class="border-t border-[#0A0A0A]/8 pt-20 mb-20">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">What We Build Together</p>
        <div class="flex flex-col divide-y divide-[#0A0A0A]/8">
          {[
            {
              label: 'Daily Content',
              line: 'Performance. Boxing. Practical self-improvement. Every day across @theerainers — the work made visible.',
            },
            {
              label: 'Weekly YouTube',
              line: 'Deep-format breakdowns on mechanics, kinetic chain, and why most training fails to transfer.',
            },
            {
              label: 'The Blueprints',
              line: 'Step-by-step video modules. Footwork. Shadowboxing. The mechanical base built correctly from the floor up.',
            },
            {
              label: 'Monthly Live Q&A',
              line: 'Live with the community. Real questions. Real corrections. The room where the work compounds.',
            },
          ].map(item => (
            <div class="grid grid-cols-[160px_1fr] py-6 gap-6 items-baseline">
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">{item.label}</p>
              <p class="text-[#0A0A0A]/40 text-sm leading-relaxed">{item.line}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Scripture -->
      <div class="border-t border-[#0A0A0A]/8 pt-20 mb-20">
        <p class="font-black text-[#0A0A0A]/12 uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88] max-w-[640px] mb-6">
          "Run in such a way as to get the prize. Every athlete exercises self-control in all things. So I do not run aimlessly; I do not box as one beating the air."
        </p>
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:24–26 · The Source Code</p>
      </div>

      <!-- CTA -->
      <div class="border-t border-[#0A0A0A]/8 pt-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
        <p class="text-[#0A0A0A]/30 text-sm max-w-[400px] leading-relaxed">The system is built. The next step is yours.</p>
        <div class="flex flex-col sm:flex-row gap-4 shrink-0">
          <a href="/vault" class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap">Get the Blueprints →</a>
          <a href="/footwork-foundation" class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/15 text-[#0A0A0A]/40 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/60 whitespace-nowrap">Start Free →</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

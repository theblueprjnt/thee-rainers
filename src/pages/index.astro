<script>
  {
    const els = document.querySelectorAll<HTMLElement>('[data-count]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1000;
        const start = performance.now();
        observer.unobserve(el);
        function step(now: number): void {
          const p = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.round(ease * target) + suffix;
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      });
    }, { threshold: 0.3 });
    els.forEach(el => observer.observe(el));
  }
</script>

<script is:inline>
  (function() {
    var STEPS = ['quiz-step-1','quiz-step-2','quiz-step-3','quiz-step-4'];
    var BARS  = ['qp-1','qp-2','qp-3'];
    var quizState = { focus: '', level: '' };

    function showStep(n) {
      STEPS.forEach(function(id, i) {
        var el = document.getElementById(id);
        if (el) el.classList.toggle('hidden', i !== n - 1);
      });
      BARS.forEach(function(id, i) {
        var el = document.getElementById(id);
        if (el) el.style.backgroundColor = i < n ? '#0057FF' : 'rgba(10,10,10,0.12)';
      });
    }

    document.querySelectorAll('[data-quiz-option][data-step="1"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        quizState.focus = btn.dataset.value || '';
        showStep(2);
      });
    });

    document.querySelectorAll('[data-quiz-option][data-step="2"]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        quizState.level = btn.dataset.value || '';
        showStep(3);
      });
    });

    var back2 = document.getElementById('quiz-back-2');
    if (back2) back2.addEventListener('click', function() { showStep(1); });

    var back3 = document.getElementById('quiz-back-3');
    if (back3) back3.addEventListener('click', function() { showStep(2); });

    var quizForm = document.getElementById('quiz-form');
    if (quizForm) {
      quizForm.addEventListener('submit', function(e) {
        e.preventDefault();
        var emailInput = document.getElementById('quiz-email');
        var submitBtn  = document.getElementById('quiz-submit');
        var errorEl    = document.getElementById('quiz-error');
        var email      = emailInput ? emailInput.value.trim() : '';

        if (!email) { if (errorEl) errorEl.classList.remove('hidden'); return; }
        if (errorEl) errorEl.classList.add('hidden');
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }

        fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, full_name: '', source: 'quiz-home', quiz_focus: quizState.focus, quiz_level: quizState.level }),
        }).catch(function() {}).finally(function() { showStep(4); });
      });
    }
  })();
</script>

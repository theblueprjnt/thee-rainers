---
import Layout from '../layouts/Base.astro';
---
<Layout title="Thee Rainers — Better training. Better results.">

  <!-- HERO -->
  <section class="w-full md:min-h-screen overflow-hidden grid grid-cols-1 md:grid-cols-[60%_40%] bg-white border-b border-[#0A0A0A]/8">

    <div class="flex flex-col justify-center px-8 md:px-14 lg:px-20 pt-28 pb-12 md:py-0 relative z-10 overflow-hidden">
      <p class="text-[#D4A373] text-xs tracking-wide uppercase mb-5">Boxing Tech · @theerainers</p>
      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-6"
        style="font-size: clamp(2.5rem, 5.5vw, 4.5rem); line-height: 0.85;">
        Engineered<br/>for the ring.
      </h1>
      <p class="text-[#0A0A0A]/55 mb-10 max-w-[380px] text-base leading-relaxed">
        Your ambition is ahead of your gym. This closes that gap.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/foundation-guide"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
          Get Free 30-Day Foundation →
        </a>
        <a href="/vault"
          class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/20 text-[#0A0A0A]/50 bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:border-[#0A0A0A]/40 hover:text-[#0A0A0A]/80 transition-all duration-200 whitespace-nowrap">
          Shop Products →
        </a>
      </div>
    </div>

    <div class="hidden md:flex items-end justify-center relative overflow-hidden bg-[#0A0A0A]">
      <img src="/images/herocropped.png" alt="Thee Rainers"
        width="1550" height="1854"
        class="hero-subject w-auto max-h-[95vh] object-contain object-bottom"
        loading="eager" decoding="async" />
    </div>

  </section>

  <!-- Mobile fighter strip -->
  <div class="md:hidden w-full overflow-hidden bg-[#0A0A0A]" style="height: 80vw; max-height: 400px;">
    <img src="/images/herocropped.png" alt="Thee Rainers"
      width="1550" height="1854"
      class="w-full h-full object-contain object-bottom" loading="eager" />
  </div>

  <!-- PRODUCTS -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto">

      <div class="mb-8">
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88]">Better Training<br/>for Better Results.</h2>
        <p class="text-[#0A0A0A]/40 text-sm mt-3">Step-by-step systems built for boxing.</p>
      </div>

      <!-- 3-column blueprint cards — Bundle leads as primary engine -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

        <div class="border-2 border-[#0057FF]/30 flex flex-col group hover:border-[#0057FF] transition-colors duration-200 relative">
          <div class="absolute top-3 left-3 z-10 bg-[#0057FF] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Best Value</div>
          <div class="bg-[#0A0A0A] overflow-hidden">
            <img src="/images/bundle_cover.png" alt="Both Blueprints Bundle"
              width="1414" height="2000"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Bundle · 100+ Rounds</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">Both Blueprints</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">Footwork + Shadowboxing. Complete system. Monthly Live Q&A included free.</p>
            <div class="mt-5 flex items-center justify-between">
              <span class="font-black text-[#0A0A0A] text-2xl">$87<span class="text-sm font-bold text-[#0A0A0A]/40">/mo</span></span>
              <a href="https://buy.stripe.com/14A4gz59hgxUaa65006J20m" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200">
                Buy →
              </a>
            </div>
          </div>
        </div>

        <div class="border border-[#0A0A0A]/10 flex flex-col group hover:border-[#0057FF]/40 transition-colors duration-200">
          <div class="bg-[#F6F6F6] overflow-hidden">
            <img src="/images/footworkbp_cover.png" alt="Footwork Blueprint"
              width="400" height="400"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Blueprint · Module 01</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">Footwork Blueprint</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">Full video breakdown. 56 drill rounds. Win fights with footwork.</p>
            <div class="mt-5 flex items-center justify-between">
              <span class="font-black text-[#0A0A0A] text-2xl">$47<span class="text-sm font-bold text-[#0A0A0A]/40">/mo</span></span>
              <a href="https://buy.stripe.com/bJe14n8lt81ogyu3VW6J20k" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200">
                Subscribe →
              </a>
            </div>
          </div>
        </div>

        <div class="border border-[#0A0A0A]/10 flex flex-col group hover:border-[#0057FF]/40 transition-colors duration-200">
          <div class="bg-[#F6F6F6] overflow-hidden">
            <img src="/images/shadowboxingblueprint_covernew.png" alt="Shadowboxing Blueprint"
              width="1500" height="1150"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Blueprint · Module 02</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">Shadowboxing Blueprint</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">Turn shadowboxing into realistic boxing. Skill tests. Range control.</p>
            <div class="mt-5 flex items-center justify-between">
              <span class="font-black text-[#0A0A0A] text-2xl">$47<span class="text-sm font-bold text-[#0A0A0A]/40">/mo</span></span>
              <a href="https://buy.stripe.com/5kQdR91X5dlIeqm8cc6J20l" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200">
                Subscribe →
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Workshop Replay — Tier 3 upsell -->
      <div class="border border-[#0A0A0A]/10 bg-[#F6F6F6] p-6 md:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">On Demand · Full Recording</p>
          <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight">Workshop Replay — $79</p>
          <p class="text-[#0A0A0A]/60 text-xs mt-2">90 min. Watch the live corrections. Apply the framework. 7-day access from purchase.</p>
        </div>
        <a href="/workshop-replay"
          class="shrink-0 blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-3 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
          Get Replay →
        </a>
      </div>

    </div>
  </section>

  <!-- FREE PROTOCOL — isolated, lean -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-12 items-center">
      <div>
        <p class="text-[#D4A373] text-xs tracking-wide uppercase mb-4">Free · Start Here</p>
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88] mb-4">30-Day Stance<br/>Foundation</h2>
        <p class="text-[#0A0A0A]/50 text-sm leading-relaxed mb-6">Most fighters train hard on a broken base. Your stance determines your power, your balance, and your defense. Fix it first — everything else follows. Free. 30 days. No equipment.</p>
        <a href="/foundation-guide"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
          Get Free 30-Day Foundation →
        </a>
      </div>
      <div class="flex flex-col gap-3">
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">Power From the Floor</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">76% of your punch power comes from the ground up. A broken base costs you before you throw a single punch.</p>
        </div>
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">Stays Under Pressure</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Drill the right movements now and they become automatic when it gets hard. That is what this builds.</p>
        </div>
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">No Gym Required</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">30 days. Just you and the work. Your body is enough.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="bg-white py-12 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto px-6 md:px-12 lg:px-20">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-[1px] bg-[#0A0A0A]/8">
        <a href="https://www.instagram.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1">331K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Instagram</p>
        </a>
        <a href="https://www.facebook.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1">110K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Facebook</p>
        </a>
        <a href="https://www.tiktok.com/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1">90K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">TikTok</p>
        </a>
        <a href="https://www.threads.net/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1">20K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Threads</p>
        </a>
        <a href="https://www.youtube.com/@Rainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200 col-span-2 md:col-span-1">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1">15K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">YouTube</p>
        </a>
      </div>
    </div>
  </section>

  <!-- SCRIPTURE -->
  <section class="bg-[#0A0A0A] px-6 md:px-12 lg:px-20 py-24">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] mb-5 text-white/50"
        style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
        "I do not run aimlessly. I do not box as one beating the air. I discipline my body and keep it under control."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26–27</p>
    </div>
  </section>

</Layout>

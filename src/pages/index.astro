---
import Layout from '../layouts/Base.astro';
---
<Layout title="Thee Rainers — Engineered for the ring.">

  <!-- HERO: 60/40 Command Grid -->
  <section class="w-full h-screen overflow-hidden grid grid-cols-1 md:grid-cols-[60%_40%]">

    <!-- Left 60%: Mission -->
    <div class="bg-[#0A0A0A] flex flex-col justify-center px-8 md:px-16 lg:px-24 relative z-10">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-8">Systemic Boxing Performance</p>
      <h1 class="font-black text-white uppercase tracking-tighter mb-8"
        style="font-size: clamp(3rem, 7vw, 5rem); line-height: 0.8;">
        Engineered<br/>for the ring.
      </h1>
      <p class="text-white/60 mb-10 max-w-[420px] text-base leading-relaxed">
        Your ambition is ahead of your gym. This closes that gap.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/footwork-foundation"
          class="inline-flex items-center justify-center font-bold transition-all duration-200 cursor-pointer no-underline border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#D4A373] hover:text-black">
          Enter the System
        </a>
        <a href="/vault"
          class="inline-flex items-center justify-center font-bold transition-all duration-200 cursor-pointer no-underline border border-white/15 text-white/35 bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:border-white/30 hover:text-white/55">
          View Products
        </a>
      </div>
    </div>

    <!-- Right 40%: Subject (You) — the anchor -->
    <div class="hidden md:block relative overflow-hidden">
      <img
        src="/images/rainers-portrait.jpg"
        alt="Thee Rainers"
        class="absolute inset-0 w-full h-full object-cover object-top"
        style="mask-image: linear-gradient(to right, transparent 0%, black 28%); -webkit-mask-image: linear-gradient(to right, transparent 0%, black 28%);"
      />
    </div>

  </section>

  <!-- TRUTH THRESHOLD: The Gate -->
  <section id="gate" class="w-full h-screen bg-[#0A0A0A] flex flex-col items-center justify-center px-8 text-center">

    <div id="gate-question" class="flex flex-col items-center">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-10">Before you continue.</p>
      <h2 class="font-black text-white uppercase tracking-tighter text-4xl md:text-[3.5rem] leading-[0.85] mb-16 max-w-[680px]">Are you building<br/>a system — or trying<br/>to get fit?</h2>
      <div class="flex flex-col sm:flex-row gap-4">
        <button
          id="btn-system"
          class="inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 cursor-pointer hover:bg-[#D4A373] hover:text-black"
        >I'm building a system.</button>
        <button
          id="btn-fit"
          class="inline-flex items-center justify-center font-bold border-2 border-white/15 text-white/25 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 cursor-pointer hover:border-white/30 hover:text-white/40"
        >I'm looking to get fit.</button>
      </div>
    </div>

    <div id="gate-rejection" style="display:none" class="flex flex-col items-center">
      <p class="text-white/30 text-[11px] tracking-widest uppercase mb-10">Understood.</p>
      <h2 class="font-black text-white uppercase tracking-tighter text-4xl md:text-[3.5rem] leading-[0.85] mb-8 max-w-[560px]">This program<br/>isn't built for that.</h2>
      <p class="text-white/40 text-base max-w-[380px] leading-relaxed mb-10">The Footwork Foundation is free. Start there. Come back when the question changes.</p>
      <a href="/footwork-foundation" class="inline-flex items-center gap-2 text-[#D4A373] text-sm font-bold tracking-widest uppercase hover:opacity-60 transition-opacity duration-200">The Footwork Foundation →</a>
    </div>

  </section>

  <!-- OFFER GRID: 60/40 Asymmetric -->
  <section class="bg-[#0A0A0A] py-20 md:py-28" id="paths" style="display:none">
    <div class="mx-auto px-8 md:px-16 lg:px-24 w-full max-w-[1280px]">

      <div class="mb-14">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">The Architecture</p>
        <h2 class="font-black text-white uppercase tracking-tighter text-4xl md:text-5xl leading-[0.85]">Select your<br/>entry point.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-[2px]">

        <!-- LEFT 60%: Private Architecture — Flagship -->
        <div class="bg-[#0D2828] p-12 md:p-16 flex flex-col justify-between min-h-[540px] group border border-[#D4A373]/20 hover:border-[#D4A373]/50 transition-colors duration-300">
          <div>
            <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">By Application Only</span>
            <h3 class="font-black text-white uppercase tracking-tighter mt-4 mb-6 text-3xl md:text-4xl leading-[0.85]">Private<br/>Architecture</h3>
            <p class="text-white/50 text-sm leading-relaxed max-w-[380px]">1 of 1. No templates. No cohorts. A system engineered around your specific fight, body, and mind. This is not coaching — it is architecture.</p>
          </div>
          <a href="/command" class="inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#D4A373] hover:text-black self-start mt-10 group-hover:gap-3">Apply →</a>
        </div>

        <!-- RIGHT 40%: Supporting Methodology — Stacked -->
        <div class="flex flex-col gap-[2px]">

          <!-- Footwork Foundation -->
          <div class="bg-[#111111] p-8 flex flex-col justify-between flex-1 border border-white/5 hover:border-[#D4A373]/20 transition-colors duration-300 group">
            <div>
              <span class="text-white/30 text-[11px] tracking-widest uppercase">Free · Entry Protocol</span>
              <h3 class="font-black text-white uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">Footwork<br/>Foundation</h3>
              <p class="text-white/40 text-xs leading-relaxed">The base layer. Required before anything else.</p>
            </div>
            <a href="/footwork-foundation" class="inline-flex items-center gap-2 text-white/50 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#D4A373] transition-colors duration-200 group-hover:gap-3">Start Here →</a>
          </div>

          <!-- Blueprints -->
          <div class="bg-[#111111] p-8 flex flex-col justify-between flex-1 border border-white/5 hover:border-[#D4A373]/20 transition-colors duration-300 group">
            <div>
              <span class="text-white/30 text-[11px] tracking-widest uppercase">Tactical Bundle</span>
              <h3 class="font-black text-white uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">Tactical<br/>Blueprints</h3>
              <p class="text-white/40 text-xs leading-relaxed">Mapped, sequenced, built for fighters who think in systems.</p>
            </div>
            <a href="https://buy.stripe.com/14A4gz59hgxUaa65006J20m" target="_blank" class="inline-flex items-center gap-2 text-white/50 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#D4A373] transition-colors duration-200 group-hover:gap-3">Get the System →</a>
          </div>

          <!-- Lab Session -->
          <div class="bg-[#111111] p-8 flex flex-col justify-between flex-1 border border-white/5 hover:border-[#D4A373]/20 transition-colors duration-300 group">
            <div>
              <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">$197 · June 27</span>
              <h3 class="font-black text-white uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">The Lab<br/>Session</h3>
              <p class="text-white/40 text-xs leading-relaxed">Live implementation. Coached in real-time.</p>
            </div>
            <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank" class="inline-flex items-center gap-2 text-white/50 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#D4A373] transition-colors duration-200 group-hover:gap-3">Reserve a Seat →</a>
          </div>

        </div>
      </div>
    </div>
  </section>


<script>
  const gate = document.getElementById('gate');
  const gateQuestion = document.getElementById('gate-question');
  const gateRejection = document.getElementById('gate-rejection');
  const paths = document.getElementById('paths');

  document.getElementById('btn-system')?.addEventListener('click', () => {
    gate.style.transition = 'opacity 0.35s ease';
    gate.style.opacity = '0';
    setTimeout(() => {
      gate.style.display = 'none';
      paths.style.display = 'block';
      paths.scrollIntoView({ behavior: 'smooth' });
    }, 350);
  });

  document.getElementById('btn-fit')?.addEventListener('click', () => {
    gateQuestion.style.transition = 'opacity 0.25s ease';
    gateQuestion.style.opacity = '0';
    setTimeout(() => {
      gateQuestion.style.display = 'none';
      gateRejection.style.display = 'flex';
      gateRejection.style.flexDirection = 'column';
      gateRejection.style.alignItems = 'center';
      gateRejection.style.opacity = '0';
      gateRejection.style.transition = 'opacity 0.35s ease';
      requestAnimationFrame(() => { gateRejection.style.opacity = '1'; });
    }, 250);
  });
</script>
</Layout>

---
import Layout from '../layouts/Base.astro';
import Rule from '../components/primitives/Rule.astro';
---
<Layout title="Thee Rainers — Boxing built on structure, not exhaustion.">
  <div class="relative" style="height: 88vh; min-height: 520px;">
    <img src="/images/rainers-hero.jpg" alt="Rainers in the gym" class="absolute inset-0 w-full h-full object-cover object-center" width="1440" height="900" />
    <div class="absolute inset-0 bg-navy/55"></div>
    <div class="relative h-full flex items-center">
      <div class="mx-auto px-6 w-full max-w-[960px]">
        <h1 class="font-bold text-white mb-5 text-5xl md:text-6xl leading-[1.05]">Composure is a physical state.</h1>
        <p class="text-white/80 mb-8 max-w-[540px] text-lg leading-[1.55]">Calm is not a personality. It is knowing where you are when it gets fast.</p>
        <a href="/footwork-foundation" class="inline-flex items-center justify-center font-semibold transition-all duration-200 cursor-pointer no-underline bg-terracotta text-white px-8 py-3.5 text-sm tracking-wide hover:opacity-90 active:opacity-80">Get the Free Blueprint</a>
      </div>
    </div>
  </div>

  <div class="bg-cream py-5">
    <div class="mx-auto px-6 w-full max-w-[960px] text-center">
      <p class="text-muted tracking-widest text-xs uppercase">Over 120 fighters coached. Riga, Latvia.</p>
    </div>
  </div>

  <section class="bg-bg py-16 md:py-20" id="paths">
    <div class="mx-auto px-6 w-full max-w-[960px]">
      <Rule />
      <h2 class="font-bold text-navy mb-8 text-3xl">Find your path in.</h2>

      <div class="divide-y divide-rule">
        <div class="py-6 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-3">
          <h3 class="font-semibold text-navy text-xl">The Footwork Foundation</h3>
          <div class="flex items-baseline gap-6 shrink-0">
            <span class="text-muted text-sm">Free</span>
            <a href="/footwork-foundation" class="text-ink underline underline-offset-4 text-sm font-semibold hover:text-terracotta">Get the guide</a>
          </div>
        </div>

        <div class="py-6 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-3">
          <h3 class="font-semibold text-navy text-xl">The Blueprints (Bundle)</h3>
          <div class="flex items-baseline gap-6 shrink-0">
            <a href="https://buy.stripe.com/14A4gz59hgxUaa65006J20m" target="_blank" class="text-ink underline underline-offset-4 text-sm font-semibold hover:text-terracotta">Buy the Bundle</a>
          </div>
        </div>

        <div class="py-6 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-3">
          <h3 class="font-semibold text-navy text-xl">The Workshop</h3>
          <div class="flex items-baseline gap-6 shrink-0">
            <span class="text-muted text-sm">$197, June 27</span>
            <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank" class="text-ink underline underline-offset-4 text-sm font-semibold hover:text-terracotta">Reserve a seat</a>
          </div>
        </div>

        <div class="py-6 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-3">
          <h3 class="font-semibold text-navy text-xl">1-on-1 Coaching</h3>
          <div class="flex items-baseline gap-6 shrink-0">
            <span class="text-muted text-sm">By application</span>
            <a href="/coaching" class="text-ink underline underline-offset-4 text-sm font-semibold hover:text-terracotta">Apply</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

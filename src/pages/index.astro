<script>
  document.querySelectorAll<HTMLButtonElement>('[data-checkout]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.checkout;
      const original = btn.textContent ?? '';
      btn.disabled = true;
      btn.textContent = 'Loading...';
      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lookupKey: key }),
        });
        const data = await res.json() as { url?: string };
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  });
</script>

<script>
  {
    const state = { focus: '', level: '' };

    function quizShow(id: string): void {
      ['quiz-step-1', 'quiz-step-2', 'quiz-step-3', 'quiz-step-4'].forEach(s => {
        document.getElementById(s)?.classList.add('hidden');
      });
      document.getElementById(id)?.classList.remove('hidden');
    }

    document.querySelectorAll<HTMLButtonElement>('[data-quiz-option][data-step="1"]').forEach(btn => {
      btn.addEventListener('click', () => {
        state.focus = btn.dataset.value ?? '';
        quizShow('quiz-step-2');
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-quiz-option][data-step="2"]').forEach(btn => {
      btn.addEventListener('click', () => {
        state.level = btn.dataset.value ?? '';
        quizShow('quiz-step-3');
      });
    });

    document.getElementById('quiz-back-2')?.addEventListener('click', () => quizShow('quiz-step-1'));
    document.getElementById('quiz-back-3')?.addEventListener('click', () => quizShow('quiz-step-2'));

    const quizForm = document.getElementById('quiz-form') as HTMLFormElement | null;
    quizForm?.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      const emailInput = document.getElementById('quiz-email') as HTMLInputElement | null;
      const submitBtn  = document.getElementById('quiz-submit') as HTMLButtonElement | null;
      const errorEl    = document.getElementById('quiz-error');
      const email      = emailInput?.value.trim() ?? '';

      if (!email) { errorEl?.classList.remove('hidden'); return; }
      errorEl?.classList.add('hidden');

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending...'; }

      try {
        await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, full_name: '', source: 'lever-audit-quiz' }),
        });
      } catch { /* non-blocking */ }

      quizShow('quiz-step-4');
    });
  }
</script>

---
import Layout from '../layouts/Base.astro';
---
<Layout title="Thee Rainers — Better training. Better results.">

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-[#0A0A0A]/8">

    <!-- Mobile: full-bleed image with dark gradient -->
    <div class="md:hidden absolute inset-0 bg-[#0A0A0A]">
      <img src="/images/coldfightpic2.jpg" alt="Thee Rainers"
        width="2280" height="2203"
        class="w-full h-full object-cover object-center opacity-70"
        loading="eager" decoding="async" />
      <div class="absolute inset-0"
        style="background: linear-gradient(to top, #0A0A0A 28%, rgba(10,10,10,0.65) 55%, rgba(10,10,10,0.1) 100%)">
      </div>
    </div>

    <!-- Grid wrapper -->
    <div class="relative z-10 md:grid md:grid-cols-[60%_40%] md:min-h-screen">

      <!-- Left: text + CTAs -->
      <div class="flex flex-col justify-end md:justify-center md:bg-white
                  px-8 md:px-14 lg:px-20
                  pt-36 pb-16 md:py-0
                  min-h-[100svh] md:min-h-0">
        <p class="text-[#D4A373] text-xs tracking-wide uppercase mb-5">Boxing Science · @theerainers</p>
        <h1 class="font-black uppercase tracking-tighter mb-6 text-white md:text-[#0A0A0A]"
          style="font-size: clamp(2.75rem, 5.5vw, 4.5rem); line-height: 0.85;">
          <span style="background: linear-gradient(to right, #FF3366, #FF9933); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Engineered</span><br/>for the ring.
        </h1>
        <p class="text-white/65 md:text-[#0A0A0A]/55 mb-10 max-w-[380px] text-base leading-relaxed">
          Your ambition is ahead of your gym. Systematic mechanics, not guesswork. This closes the gap.
        </p>
        <div class="flex flex-col lg:flex-row gap-3">
          <a href="/foundation-guide"
            class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
            Get Free 30-Day Foundation →
          </a>
          <a href="/vault"
            class="inline-flex items-center justify-center font-bold bg-[#0057FF] text-white px-10 py-4 text-sm uppercase tracking-widest hover:bg-[#0040CC] transition-colors duration-200 whitespace-nowrap border-none">
            See the Blueprints →
          </a>
        </div>
      </div>

      <!-- Right: desktop image panel -->
      <div class="hidden md:block relative overflow-hidden bg-[#0A0A0A]">
        <img src="/images/coldfightpic2.jpg" alt="Thee Rainers"
          width="2280" height="2203"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="eager" decoding="async" />
      </div>

    </div>
  </section>

  <!-- QUIZ — 3-step diagnosis -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[860px] mx-auto">

      <!-- Header + progress -->
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">3-Step Diagnosis · Free</p>
          <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88]">Find your<br/>starting point.</h2>
        </div>
        <div class="flex gap-1.5">
          <div id="qp-1" class="h-[3px] w-14 transition-all duration-300" style="background-color:#0057FF"></div>
          <div id="qp-2" class="h-[3px] w-14 transition-all duration-300" style="background-color:rgba(10,10,10,0.12)"></div>
          <div id="qp-3" class="h-[3px] w-14 transition-all duration-300" style="background-color:rgba(10,10,10,0.12)"></div>
        </div>
      </div>

      <!-- Step 1 -->
      <div id="quiz-step-1">
        <p class="text-[#0A0A0A]/35 text-[10px] tracking-widest uppercase mb-6">What is your primary focus right now?</p>
        <div class="grid grid-cols-2 gap-3">
          <button data-quiz-option data-step="1" data-value="speed"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Speed</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Hand speed and combination flow</p>
          </button>
          <button data-quiz-option data-step="1" data-value="power"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Power</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Kinetic chain and punch mechanics</p>
          </button>
          <button data-quiz-option data-step="1" data-value="footwork"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Footwork</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Movement, angles, and control</p>
          </button>
          <button data-quiz-option data-step="1" data-value="ringiq"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Ring IQ</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Reads, tactics, and decision-making</p>
          </button>
        </div>
      </div>

      <!-- Step 2 -->
      <div id="quiz-step-2" class="hidden">
        <button id="quiz-back-2" class="text-[#0A0A0A]/30 text-[10px] tracking-widest uppercase mb-4 flex items-center gap-2 hover:text-[#0A0A0A]/60 transition-colors cursor-pointer bg-transparent border-0 py-3 px-1 font-bold min-h-[44px]">
          &larr; Back
        </button>
        <p class="text-[#0A0A0A]/35 text-[10px] tracking-widest uppercase mb-6">Where are you starting from?</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <button data-quiz-option data-step="2" data-value="beginner"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Just starting</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Under 1 year or no formal training</p>
          </button>
          <button data-quiz-option data-step="2" data-value="amateur"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Amateur</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Training consistently, have sparred</p>
          </button>
          <button data-quiz-option data-step="2" data-value="advanced"
            class="border border-[#0A0A0A]/10 bg-[#F7F6F4] hover:border-[#0057FF] hover:bg-white transition-colors duration-150 cursor-pointer p-6 text-left w-full">
            <p class="font-black text-[#0A0A0A] uppercase tracking-tight text-sm mb-1.5">Advanced</p>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Competitive or serious fight record</p>
          </button>
        </div>
      </div>

      <!-- Step 3: Email -->
      <div id="quiz-step-3" class="hidden">
        <button id="quiz-back-3" class="text-[#0A0A0A]/30 text-[10px] tracking-widest uppercase mb-4 flex items-center gap-2 hover:text-[#0A0A0A]/60 transition-colors cursor-pointer bg-transparent border-0 py-3 px-1 font-bold min-h-[44px]">
          &larr; Back
        </button>
        <h3 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl leading-[0.88] mb-3">Get your free protocol.</h3>
        <p class="text-[#0A0A0A]/40 text-sm leading-relaxed mb-8 max-w-[420px]">Based on your answers — the right starting point, sent to your inbox. Free.</p>
        <form id="quiz-form" class="flex flex-col sm:flex-row gap-3 max-w-[520px]">
          <input type="email" id="quiz-email" placeholder="your@email.com" required
            class="flex-1 border border-[#0A0A0A]/15 bg-[#F7F6F4] px-5 py-4 text-sm text-[#0A0A0A] placeholder:text-[#0A0A0A]/25 focus:outline-none focus:border-[#0057FF] transition-colors duration-200" />
          <button type="submit" id="quiz-submit"
            class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap cursor-pointer disabled:opacity-40">
            Send Protocol →
          </button>
        </form>
        <p id="quiz-error" class="text-[#0A0A0A]/40 text-xs mt-3 hidden">Please enter a valid email address.</p>
      </div>

      <!-- Step 4: Done -->
      <div id="quiz-step-4" class="hidden">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Sent</p>
        <h3 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl leading-[0.88] mb-3">Check your inbox.</h3>
        <p class="text-[#0A0A0A]/40 text-sm leading-relaxed max-w-[400px]">Your free protocol is on the way. Build the base. Everything else follows.</p>
      </div>

    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto">

      <div class="mb-8">
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88]">Better Training<br/>for Better Results.</h2>
        <p class="text-[#0A0A0A]/40 text-sm mt-3">Step-by-step systems built for boxing.</p>
      </div>

      <!-- 3-column blueprint cards — Bundle leads -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">

        <div class="tr-card border-2 border-[#0057FF]/30 flex flex-col group hover:border-[#0057FF] transition-colors duration-200 relative">
          <div class="absolute top-3 left-3 z-10 bg-[#0057FF] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Best Value</div>
          <div class="bg-[#0A0A0A] overflow-hidden relative">
            <img src="/images/bundle_cover.png" alt="Both Blueprints Bundle"
              width="1414" height="2000"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Bundle · 100+ Rounds</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-3">Both Blueprints</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">The complete system. Foundation first. Application second. Both modules running in sequence.</p>
            <div class="mt-5 flex items-center justify-between">
              <div>
                <span class="font-black text-[#0A0A0A] text-2xl">$87</span>
                <p class="text-[10px] text-[#0A0A0A]/30 mt-0.5">One-time purchase</p>
              </div>
              <a href="https://buy.stripe.com/14A4gz59hgxUaa65006J20m"
                class="inline-flex items-center justify-center whitespace-nowrap bg-[#0057FF] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#0040CC] transition-colors duration-200">
                Buy Bundle →
              </a>
            </div>
            <p class="text-[9px] text-[#0A0A0A]/25 mt-2 text-right"><a href="/legal/terms" class="underline hover:text-[#0A0A0A]/50">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]/50">Refund Policy</a></p>
          </div>
        </div>

        <div class="tr-card border border-[#0A0A0A]/10 flex flex-col group hover:border-[#0057FF]/40 transition-colors duration-200">
          <div class="bg-[#F6F6F6] overflow-hidden relative">
            <img src="/images/footworkbp_cover.png" alt="Footwork Blueprint"
              width="400" height="400"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Blueprint · Module 01</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-3">Footwork Blueprint</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">Stance mechanics. Weight distribution. Kinetic chain from the floor up. The base layer.</p>
            <div class="mt-4 flex items-center justify-between">
              <div>
                <span class="font-black text-[#0A0A0A] text-2xl">$47</span>
                <p class="text-[10px] text-[#0A0A0A]/30 mt-0.5">One-time purchase</p>
              </div>
              <a href="https://buy.stripe.com/bJe14n8lt81ogyu3VW6J20k"
                class="inline-flex items-center justify-center whitespace-nowrap bg-[#0057FF] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#0040CC] transition-colors duration-200">
                Buy Now →
              </a>
            </div>
            <p class="text-[9px] text-[#0A0A0A]/25 mt-2 text-right"><a href="/legal/terms" class="underline hover:text-[#0A0A0A]/50">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]/50">Refund Policy</a></p>
          </div>
        </div>

        <div class="tr-card border border-[#0A0A0A]/10 flex flex-col group hover:border-[#0057FF]/40 transition-colors duration-200">
          <div class="bg-[#F6F6F6] overflow-hidden relative">
            <img src="/images/shadowboxingblueprint_covernew.png" alt="Shadowboxing Blueprint"
              width="1500" height="1150"
              class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Blueprint · Module 02</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-3">Shadowboxing Blueprint</h3>
            <p class="text-[#0A0A0A]/40 text-xs leading-relaxed flex-1">Shadowboxing rebuilt as live simulation. Cue reading. Range fluency. Technique under pressure.</p>
            <div class="mt-4 flex items-center justify-between">
              <div>
                <span class="font-black text-[#0A0A0A] text-2xl">$47</span>
                <p class="text-[10px] text-[#0A0A0A]/30 mt-0.5">One-time purchase</p>
              </div>
              <a href="https://buy.stripe.com/5kQdR91X5dlIeqm8cc6J20l"
                class="inline-flex items-center justify-center whitespace-nowrap bg-[#0057FF] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#0040CC] transition-colors duration-200">
                Buy Now →
              </a>
            </div>
            <p class="text-[9px] text-[#0A0A0A]/25 mt-2 text-right"><a href="/legal/terms" class="underline hover:text-[#0A0A0A]/50">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]/50">Refund Policy</a></p>
          </div>
        </div>

      </div>

      <!-- Workshop Replay -->
      <div class="relative overflow-hidden bg-[#0A0A0A] mb-4">
        <img src="/images/workshop_bacgkround.png" alt="Defense Workshop live session"
          width="1920" height="1080"
          class="absolute inset-0 w-full h-full object-cover object-center opacity-35"
          loading="lazy" />
        <div class="relative z-10 p-6 md:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
          <div>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">On Demand · Full Recording</p>
            <p class="font-black text-white uppercase tracking-tight text-xl leading-tight">Workshop Replay — $79</p>
            <p class="text-white/50 text-xs mt-2">90 min. Watch the live corrections. Apply the framework. 7-day access from purchase.</p>
          </div>
          <a href="/workshop-replay"
            class="shrink-0 inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-3 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
            Get Replay →
          </a>
        </div>
      </div>

      <!-- Greatness Community -->
      <div class="border border-[#6A0DAD]/20 overflow-hidden">
        <div class="p-8 md:p-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
          <div>
            <p class="text-[#6A0DAD] text-[10px] tracking-widest uppercase mb-3">Greatness Community</p>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-2xl leading-tight mb-3">Want live reps with Rainers?</h3>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed max-w-[520px]">Weekly live Proving Ground sessions with Rainers. Real-time correction on your movement. Private community chat. Drill library. $39/mo.</p>
          </div>
          <a href="/community"
            class="shrink-0 inline-flex items-center justify-center whitespace-nowrap bg-[#6A0DAD] text-white font-bold px-8 py-3 text-xs uppercase tracking-widest hover:bg-[#5a0b92] transition-colors duration-200">
            See the Community →
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- FREE PROTOCOL — isolated, lean -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-12 items-center">
      <div>
        <p class="text-[#D4A373] text-xs tracking-wide uppercase mb-4">Free · Start Here</p>
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-3xl md:text-4xl leading-[0.88] mb-4">30-Day Stance<br/>Foundation</h2>
        <p class="text-[#0A0A0A]/50 text-sm leading-relaxed mb-6">Most fighters train hard on a broken base. Your stance determines your power, your balance, and your defense. Fix it first — everything else follows. Free. 30 days. No equipment.</p>
        <a href="/foundation-guide"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
          Get Free 30-Day Foundation →
        </a>
      </div>
      <div class="flex flex-col gap-3">
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">Power From the Floor</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">76% of your punch power comes from the ground up. A broken base costs you before you throw a single punch.</p>
        </div>
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">Stays Under Pressure</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Drill the right movements now and they become automatic when it gets hard. That is what this builds.</p>
        </div>
        <div class="border-l-2 border-[#D4A373] pl-4 py-1">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-1">No Gym Required</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">30 days. Just you and the work. Your body is enough.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="bg-white py-12 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto px-6 md:px-12 lg:px-20">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-[1px] bg-[#0A0A0A]/8">
        <a href="https://www.instagram.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1" data-count="331" data-suffix="K">331K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Instagram</p>
        </a>
        <a href="https://www.facebook.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1" data-count="110" data-suffix="K">110K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Facebook</p>
        </a>
        <a href="https://www.tiktok.com/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1" data-count="90" data-suffix="K">90K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">TikTok</p>
        </a>
        <a href="https://www.threads.net/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-2xl md:text-3xl leading-none mb-1" data-count="20" data-suffix="K">20K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Threads</p>
        </a>
        <a href="https://www.youtube.com/@Rainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-8 px-4 hover:bg-[#F6F6F6] transition-colors duration-200 col-span-2 md:col-span-1">

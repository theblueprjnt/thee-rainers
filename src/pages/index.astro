---
import Layout from '../layouts/Base.astro';
---
<Layout title="Thee Rainers — Engineered for the ring.">

  <!-- HERO: 60/40 — Subject stands on the page -->
  <section class="w-full min-h-screen overflow-hidden grid grid-cols-1 md:grid-cols-[60%_40%] bg-white border-b border-[#0A0A0A]/8">

    <!-- Left 60%: Mission -->
    <div class="flex flex-col justify-center px-8 md:px-16 lg:px-24 pt-32 pb-16 md:py-0 relative z-10">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-8">Systemic Boxing Performance</p>
      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-8"
        style="font-size: clamp(3rem, 7vw, 5rem); line-height: 0.8;">
        Engineered<br/>for the ring.
      </h1>
      <p class="text-[#0A0A0A]/55 mb-10 max-w-[420px] text-base leading-relaxed">
        Your ambition is ahead of your gym. This closes that gap.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#gate"
          class="blue-btn inline-flex items-center justify-center font-bold transition-all duration-200 cursor-pointer no-underline border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:bg-[#0057FF] hover:text-white">
          Enter the System
        </a>
        <a href="/vault"
          class="inline-flex items-center justify-center font-bold transition-all duration-200 cursor-pointer no-underline border border-[#0A0A0A]/15 text-[#0A0A0A]/40 bg-transparent px-10 py-4 text-sm tracking-widest uppercase hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/70">
          View Products
        </a>
      </div>
    </div>

    <!-- Right 40%: Subject stands on the page -->
    <div class="hidden md:flex items-end justify-center relative overflow-hidden">
      <img
        src="/images/myherocutout.jpg"
        alt="Thee Rainers"
        class="hero-subject w-auto max-h-[95vh] object-contain object-bottom"
        loading="eager"
        decoding="async"
      />
    </div>

  </section>

  <!-- GATE: Path Choice -->
  <section id="gate" class="w-full min-h-screen bg-white flex flex-col items-center justify-center px-8 text-center py-24 border-b border-[#0A0A0A]/8">

    <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-10">Before you continue.</p>
    <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter leading-[0.85] mb-6 max-w-[720px]"
      style="font-size: clamp(2.5rem, 6vw, 4rem);">
      Are you training<br/>to compete —<br/>or building<br/>your foundation?
    </h2>
    <p class="text-[#0A0A0A]/35 text-sm mb-16 max-w-[420px] leading-relaxed">
      Both paths start free. Your answer determines which tool you need first.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 mb-6">
      <a href="/lever-audit"
        class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-5 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
        I Want to Compete →
      </a>
      <a href="/footwork-foundation"
        class="inline-flex items-center justify-center font-bold border-2 border-[#0A0A0A]/20 text-[#0A0A0A]/60 bg-transparent px-10 py-5 text-sm tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/40 hover:text-[#0A0A0A]">
        I Want to Get Fit →
      </a>
    </div>

    <a href="/footwork-foundation"
      class="text-[#0A0A0A]/25 text-xs tracking-widest uppercase hover:text-[#0A0A0A]/50 transition-colors duration-200 underline underline-offset-4">
      Not sure yet — start with the foundation
    </a>

  </section>

  <!-- OFFER GRID: Product Architecture -->
  <section class="bg-white py-20 md:py-28 border-b border-[#0A0A0A]/8">
    <div class="mx-auto px-8 md:px-16 lg:px-24 w-full max-w-[1280px]">

      <div class="mb-14">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">The Architecture</p>
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.85]">Select your<br/>entry point.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-[1px] bg-[#0A0A0A]/8">

        <!-- LEFT 60%: Private Architecture — Flagship -->
        <div class="bg-[#F0EEFF] p-12 md:p-16 flex flex-col justify-between min-h-[540px] group border border-[#6A0DAD]/20 hover:border-[#6A0DAD]/50 transition-colors duration-300">
          <div>
            <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">By Application Only</span>
            <h3 class="font-black text-[#0A0A0A] uppercase tracking-tighter mt-4 mb-6 text-3xl md:text-4xl leading-[0.85]">Private<br/>Architecture</h3>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed max-w-[380px]">1 of 1. No templates. No cohorts. A system engineered around your specific fight, body, and mind. This is not coaching — it is architecture.</p>
          </div>
          <a href="/command" class="purple-btn inline-flex items-center justify-center font-bold border-2 border-[#6A0DAD] text-[#6A0DAD] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#6A0DAD] hover:text-white self-start mt-10">Apply →</a>
        </div>

        <!-- RIGHT 40%: Supporting Methodology -->
        <div class="flex flex-col gap-[1px] bg-[#0A0A0A]/8">

          <!-- 7-Lever Audit -->
          <div class="bg-white p-8 flex flex-col justify-between flex-1 group hover:bg-[#F6F6F6] transition-colors duration-300">
            <div>
              <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">Free · Competitors</span>
              <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">7-Lever<br/>Audit</h3>
              <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Find the leak in your system before your next fight.</p>
            </div>
            <a href="/lever-audit" class="inline-flex items-center gap-2 text-[#0A0A0A]/40 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#0057FF] transition-colors duration-200 group-hover:gap-3">Get the Audit →</a>
          </div>

          <!-- Footwork Foundation -->
          <div class="bg-white p-8 flex flex-col justify-between flex-1 group hover:bg-[#F6F6F6] transition-colors duration-300">
            <div>
              <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">Free · Foundation</span>
              <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">Footwork<br/>Foundation</h3>
              <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">The base layer. 30-day protocol. Required before anything else.</p>
            </div>
            <a href="/footwork-foundation" class="inline-flex items-center gap-2 text-[#0A0A0A]/40 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#0057FF] transition-colors duration-200 group-hover:gap-3">Start Here →</a>
          </div>

          <!-- Lab Session -->
          <div class="bg-white p-8 flex flex-col justify-between flex-1 group hover:bg-[#F6F6F6] transition-colors duration-300">
            <div>
              <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">$197 · June 27</span>
              <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight mt-3 mb-3 text-xl leading-tight">The Lab<br/>Session</h3>
              <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Live implementation. Coached in real-time.</p>
            </div>
            <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank" class="inline-flex items-center gap-2 text-[#0A0A0A]/40 text-xs font-bold tracking-widest uppercase mt-6 hover:text-[#0057FF] transition-colors duration-200 group-hover:gap-3">Reserve a Seat →</a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF: Community reach -->
  <section class="bg-white py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto px-8 md:px-16 lg:px-24">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-10 text-center">The Community</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-[1px] bg-[#0A0A0A]/8">

        <a href="https://www.instagram.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-10 px-6 group hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-3xl md:text-4xl leading-none mb-2">331K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Instagram</p>
          <p class="text-[#0A0A0A]/25 text-[10px] mt-1">@theerainers</p>
        </a>

        <a href="https://www.facebook.com/theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-10 px-6 group hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-3xl md:text-4xl leading-none mb-2">110K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Facebook</p>
          <p class="text-[#0A0A0A]/25 text-[10px] mt-1">Blueprint Boxing</p>
        </a>

        <a href="https://www.tiktok.com/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-10 px-6 group hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-3xl md:text-4xl leading-none mb-2">90K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">TikTok</p>
          <p class="text-[#0A0A0A]/25 text-[10px] mt-1">@theerainers</p>
        </a>

        <a href="https://www.threads.net/@theerainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-10 px-6 group hover:bg-[#F6F6F6] transition-colors duration-200">
          <p class="font-black text-[#0A0A0A] text-3xl md:text-4xl leading-none mb-2">20K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Threads</p>
          <p class="text-[#0A0A0A]/25 text-[10px] mt-1">@theerainers</p>
        </a>

        <a href="https://www.youtube.com/@Rainers" target="_blank" rel="noopener"
          class="bg-white flex flex-col items-center justify-center py-10 px-6 group hover:bg-[#F6F6F6] transition-colors duration-200 col-span-2 md:col-span-1">
          <p class="font-black text-[#0A0A0A] text-3xl md:text-4xl leading-none mb-2">15K</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">YouTube</p>
          <p class="text-[#0A0A0A]/25 text-[10px] mt-1">@Rainers</p>
        </a>

      </div>
      <p class="text-center text-[#0A0A0A]/25 text-xs tracking-wide mt-8">
        Follow for daily training content, system breakdowns, and fight prep.
      </p>
    </div>
  </section>

  <!-- SCRIPTURE ANCHOR -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-28">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="font-black uppercase tracking-tighter leading-[0.88] mb-6 text-white/10"
        style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
        "I do not run aimlessly. I do not box as one beating the air. I discipline my body and keep it under control."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26–27</p>
    </div>
  </section>

</Layout>

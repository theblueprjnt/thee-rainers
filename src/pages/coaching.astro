---
import Layout from '../layouts/Base.astro';
---
<Layout title="Coaching Application | Thee Rainers">
  <section class="max-w-[720px] mx-auto px-6 py-24 md:py-32">
    <h1 class="text-5xl md:text-6xl font-bold text-navy mb-6 leading-[1.05]">Structure beats dependence.</h1>
    <p class="text-lg text-ink mb-12 leading-[1.65]">
      I do not train hobbyists. I train fighters who are ready to rebuild their mechanics from the ground up. If you are accepted, you get the blueprint. Fill out the intake below.
    </p>

    <form id="coaching-form" class="flex flex-col gap-8">
      <div class="flex flex-col gap-2">
        <label for="name" class="font-semibold text-xs tracking-widest uppercase text-muted">Full Name</label>
        <input type="text" id="name" required class="border-b-2 border-rule bg-transparent p-2 focus:border-navy focus:outline-none transition-colors" />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="font-semibold text-xs tracking-widest uppercase text-muted">Email</label>
        <input type="email" id="email" required class="border-b-2 border-rule bg-transparent p-2 focus:border-navy focus:outline-none transition-colors" />
      </div>

      <div class="flex flex-col gap-2">
        <label for="record" class="font-semibold text-xs tracking-widest uppercase text-muted">1. What is your current fight record and training structure?</label>
        <textarea id="record" rows="3" required class="border-2 border-rule bg-transparent p-3 focus:border-navy focus:outline-none transition-colors resize-y"></textarea>
      </div>

      <div class="flex flex-col gap-2">
        <label for="flaw" class="font-semibold text-xs tracking-widest uppercase text-muted">2. Where do your mechanics break down under pressure?</label>
        <textarea id="flaw" rows="3" required class="border-2 border-rule bg-transparent p-3 focus:border-navy focus:outline-none transition-colors resize-y"></textarea>
      </div>

      <button type="submit" class="mt-4 bg-navy text-white px-8 py-4 font-bold text-lg hover:opacity-90 transition-opacity duration-200 w-full md:w-auto self-start">
        Submit Application
      </button>

      <p id="form-status" class="hidden font-medium mt-2 text-terracotta"></p>
    </form>
  </section>

  <script>
    const form = document.getElementById('coaching-form');
    const status = document.getElementById('form-status');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.classList.remove('hidden');
      status.innerText = "Transmitting application...";

      const payload = {
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        record: document.getElementById('record').value,
        flaw: document.getElementById('flaw').value,
        source: 'High-Ticket Application'
      };

      try {
        const response = await fetch('/api/coaching-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          form.reset();
          status.innerText = "Application received. I will review your structure.";
          status.classList.replace('text-terracotta', 'text-navy');
        } else {
          throw new Error('Network error');
        }
      } catch (error) {
        status.innerText = "Transmission failed. Contact me directly on Instagram.";
      }
    });
  </script>
</Layout>

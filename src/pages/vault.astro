---
import Layout from '../layouts/Base.astro';

const products = [
  {
    image: '/images/bundle_cover.png',
    tag: 'Bundle · Best Value',
    title: 'Both Blueprints',
    sub: '100+ Rounds · Full System',
    desc: 'Footwork + Shadowboxing. Complete operating system. Monthly Live Q&A included free.',
    price: '$87/mo',
    lookupKey: 'bundle_monthly',
    featured: true,
  },
  {
    image: '/images/footworkbp_cover.png',
    tag: 'Blueprint · Module 01',
    title: 'Footwork Blueprint',
    sub: 'Win Fights with Footwork',
    desc: 'Full video breakdown. 56 drill rounds. 30-day progression. The base everything else runs on.',
    price: '$47/mo',
    lookupKey: 'footwork_monthly',
    featured: false,
  },
  {
    image: '/images/shadowboxingblueprint_covernew.png',
    tag: 'Blueprint · Module 02',
    title: 'Shadowboxing Blueprint',
    sub: 'Turn Shadowboxing Into Real Boxing',
    desc: 'Done-with-you session. Skill tests. Range control. The kinetic chain applied in motion.',
    price: '$47/mo',
    lookupKey: 'shadowboxing_monthly',
    featured: false,
  },
];

const productSchema = JSON.stringify(products.map(p => ({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": p.title,
  "description": p.desc,
  "url": "https://theerainers.com/vault",
  "brand": { "@type": "Brand", "name": "Thee Rainers" },
  "offers": {
    "@type": "Offer",
    "price": parseFloat(p.price.replace(/[^0-9.]/g, '')),
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://theerainers.com/vault",
  },
})));
---
<Layout title="Blueprints — Thee Rainers" description="Step-by-step systems built for boxing. Better training for better results.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={productSchema} />
  </Fragment>

  <section class="bg-white px-6 md:px-12 lg:px-20 pt-28 md:pt-36 pb-20">
    <div class="max-w-[1100px] mx-auto">

      <!-- Header — tight, direct -->
      <div class="mb-10">
        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.88]">Better Training<br/>for Better Results.</h1>
        <p class="text-[#0A0A0A]/45 text-sm mt-4">Step-by-step systems built for boxing.</p>
      </div>

      <!-- 3-column product cards — bundle leads -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {products.map(p => (
          <div class={`flex flex-col group transition-colors duration-200 relative ${p.featured ? 'border-2 border-[#0057FF]/30 hover:border-[#0057FF]' : 'border border-[#0A0A0A]/10 hover:border-[#0057FF]/40'}`}>
            {p.featured && <div class="absolute top-3 left-3 z-10 bg-[#0057FF] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Best Value</div>}
            <!-- Cover image -->
            <div class={`overflow-hidden ${p.featured ? 'bg-[#0A0A0A]' : 'bg-[#F6F6F6]'}`}>
              <img src={p.image} alt={p.title}
                loading="lazy"
                class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
            </div>
            <!-- Card body -->
            <div class="p-5 flex flex-col flex-1">
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">{p.tag}</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">{p.title}</h2>
              <p class="text-[#0A0A0A]/50 text-xs mb-3 font-bold">{p.sub}</p>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed flex-1">{p.desc}</p>
              {!p.featured && (
                <div class="flex items-center gap-2 mt-4 pt-4 border-t border-[#D4A373]/20">
                  <span class="text-[#D4A373] text-[9px] font-black tracking-widest uppercase">+ Monthly Live Q&A</span>
                  <span class="text-[#0A0A0A]/25 text-[9px] tracking-widest uppercase">Included free</span>
                </div>
              )}
              <div class="mt-4 flex items-center justify-between">
                <span class="font-black text-[#0A0A0A] text-2xl">{p.price}</span>
                <button data-checkout={p.lookupKey}
                  class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap cursor-pointer disabled:opacity-40">
                  {p.featured ? 'Get Bundle →' : 'Subscribe →'}
                </button>
              </div>
              <p class="text-[9px] text-[#0A0A0A]/25 mt-2 text-right leading-relaxed">
                By purchasing you agree to our <a href="/legal/terms" class="underline hover:text-[#0A0A0A]/50">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]/50">Refund Policy</a>.
              </p>
              {!p.featured && (
                <p class="text-[10px] text-[#0A0A0A]/30 mt-3 text-center leading-relaxed">
                  Get both Blueprints + Monthly Q&A for&nbsp;
                  <button data-checkout="bundle_monthly"
                    class="text-[#0057FF] font-bold hover:opacity-60 transition-opacity cursor-pointer disabled:opacity-40 bg-transparent border-0 p-0 text-[10px]">
                    $87/mo →
                  </button>
                </p>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Workshop + Q&A row — live offers -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">

        <div class="border border-[#D4A373]/30 bg-[#0A0A0A] p-8 flex flex-col justify-between group hover:border-[#D4A373]/60 transition-colors duration-200">
          <div>
            <!-- TODO: POST-JUNE-27 DATE SWAP -->
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Live · June 27 · 90 min</p>
            <h2 class="font-black text-white uppercase tracking-tight text-2xl leading-tight mb-3">Defense Workshop</h2>
            <p class="text-white/40 text-xs leading-relaxed">Camera on. Real-time correction on your movement. The mechanical structure to hit, exit, and reset.</p>
          </div>
          <div class="flex items-center justify-between mt-8">
            <span class="font-black text-white text-2xl">$197</span>
            <div class="flex flex-col items-end gap-1">
              <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                Reserve Seat →
              </a>
              <p class="text-[9px] text-white/25 leading-relaxed">
                <a href="/legal/terms" class="underline hover:text-white/50">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-white/50">Refund Policy</a>
              </p>
            </div>
          </div>
        </div>

        <div class="border border-[#0A0A0A]/10 bg-[#F6F6F6] flex flex-col justify-between group hover:border-[#0057FF]/30 transition-colors duration-200">
          <div class="bg-[#0A0A0A] flex items-center justify-center py-8 px-6">
            <img src="/images/trb-logo-nobg.png" alt="Workshop Replay"
              class="h-20 w-auto opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
          </div>
          <div class="p-8 flex flex-col flex-1 justify-between">
            <div>
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">On Demand · Full Recording</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-2xl leading-tight mb-3">Workshop Replay</h2>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed">The full 90-min session. Watch the corrections. Footwork, stance, punch mechanics. Apply the framework. 7-day access window from purchase.</p>
            </div>
            <div class="flex items-center justify-between mt-8">
              <span class="font-black text-[#0A0A0A] text-2xl">$79</span>
              <a href="/workshop-replay"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                Get Replay →
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- PA strip — Instagram gradient border signals exclusivity -->
      <div class="mt-4 p-[2px]" style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888)">
        <div class="bg-[#0A0A0A] p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
          <div>
            <p class="text-[10px] tracking-widest uppercase mb-2"
              style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
              Application Only · 1 of 1
            </p>
            <h2 class="font-black text-white uppercase tracking-tight text-2xl leading-tight mb-2">Private Architecture</h2>
            <p class="text-white/35 text-xs max-w-[500px] leading-relaxed">No templates. No cohorts. A system engineered entirely around your fight, your body, your mind.</p>
          </div>
          <a href="/command"
            class="shrink-0 inline-flex items-center justify-center font-bold text-white px-8 py-3 text-xs tracking-widest uppercase whitespace-nowrap transition-opacity duration-200 hover:opacity-80"
            style="background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888)">
            Apply →
          </a>
        </div>
      </div>

      <!-- Monthly Q&A Community Call — free bonus block -->
      <div class="mt-4 border border-[#D4A373]/25 bg-white overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] items-center gap-0">
          <div class="p-8 md:p-10">
            <div class="flex items-center gap-3 mb-5">
              <span class="bg-[#D4A373]/15 border border-[#D4A373]/30 text-[#D4A373] text-[9px] font-black tracking-widest uppercase px-3 py-1.5">Included Free</span>
              <span class="text-[#0A0A0A]/20 text-[9px] tracking-widest uppercase">With Every Blueprint</span>
            </div>
            <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-2xl md:text-3xl leading-[0.88] mb-3">Monthly Q&A<br/>Community Call</h2>
            <p class="text-[#0A0A0A]/45 text-sm leading-relaxed max-w-[480px] mb-6">One Saturday per month. One hour. You bring the problem — we apply the 7-lever operating system to it live. Real-time diagnosis. No fluff. Included free with any Blueprint purchase.</p>
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <div class="flex items-center gap-6">
                <div>
                  <p class="text-[#D4A373] text-[9px] tracking-widest uppercase mb-0.5">Format</p>
                  <p class="text-[#0A0A0A]/60 text-xs font-bold">Live · Zoom · Camera on</p>
                </div>
                <div class="w-px h-8 bg-[#0A0A0A]/8"></div>
                <div>
                  <p class="text-[#D4A373] text-[9px] tracking-widest uppercase mb-0.5">Cadence</p>
                  <p class="text-[#0A0A0A]/60 text-xs font-bold">Every month · 1 hour</p>
                </div>
                <div class="w-px h-8 bg-[#0A0A0A]/8"></div>
                <div>
                  <p class="text-[#D4A373] text-[9px] tracking-widest uppercase mb-0.5">Cost</p>
                  <p class="font-black text-[#D4A373] text-xs">Free</p>
                </div>
              </div>
            </div>
          </div>
          <div class="hidden md:flex flex-col items-center justify-center bg-[#0A0A0A] px-12 py-10 self-stretch min-w-[200px]">
            <p class="font-black text-white/15 uppercase tracking-tighter text-[3rem] leading-none mb-1">1×</p>
            <p class="text-[#D4A373] text-[9px] tracking-widest uppercase text-center">Per Month<br/>Included</p>
          </div>
        </div>
      </div>

      <!-- Start free nudge -->
      <div class="mt-10 pt-10 border-t border-[#0A0A0A]/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-[#0A0A0A]/30 text-sm">Not ready to buy? The foundation protocol is free.</p>
        <a href="/foundation-guide" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity whitespace-nowrap">Get the Free Protocol →</a>
      </div>

    </div>
  </section>

  <!-- Scripture -->
  <section class="bg-[#0A0A0A] px-6 md:px-12 lg:px-20 py-20">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] text-white/50 text-2xl md:text-3xl mb-4">
        "I do not run aimlessly. I do not box as one beating the air."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26–27</p>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-checkout]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.checkout;
      const original = btn.textContent ?? '';
      btn.disabled = true;
      btn.textContent = 'Loading...';
      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lookupKey: key }),
        });
        const data = await res.json() as { url?: string };
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.disabled = false;
          btn.textContent = original;
        }
      } catch {
        btn.disabled = false;
        btn.textContent = original;
      }
    });
  });
</script>

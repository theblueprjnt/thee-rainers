---
import Layout from '../layouts/Base.astro';

const products = [
  {
    image: '/images/bundle_cover.png',
    tag: 'Bundle · Best Value',
    title: 'Both Blueprints',
    sub: '100+ Rounds · Full System',
    desc: 'Footwork + Shadowboxing. Complete operating system. Monthly Live Q&A included.',
    price: '$87',
    url: 'https://buy.stripe.com/14A4gz59hgxUaa65006J20m',
    featured: true,
  },
  {
    image: '/images/footworkbp_cover.png',
    tag: 'Blueprint · Module 01',
    title: 'Footwork Blueprint',
    sub: 'Win Fights with Footwork',
    desc: 'Full video breakdown. 56 drill rounds. 30-day progression. The base everything else runs on.',
    price: '$47',
    url: 'https://buy.stripe.com/bJe14n8lt81ogyu3VW6J20k',
    featured: false,
  },
  {
    image: '/images/shadowboxingblueprint_covernew.png',
    tag: 'Blueprint · Module 02',
    title: 'Shadowboxing Blueprint',
    sub: 'Turn Shadowboxing Into Real Boxing',
    desc: 'Done-with-you session. Skill tests. Range control. The kinetic chain applied in motion.',
    price: '$47',
    url: 'https://buy.stripe.com/5kQdR91X5dlIeqm8cc6J20l',
    featured: false,
  },
];

const productSchema = JSON.stringify(products.map(p => ({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": p.title,
  "description": p.desc,
  "url": "https://theerainers.com/vault",
  "brand": { "@type": "Brand", "name": "Thee Rainers" },
  "offers": {
    "@type": "Offer",
    "price": p.price.replace('$', ''),
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": p.url,
  },
})));
---
<Layout title="Blueprints — Thee Rainers" description="Step-by-step systems built for boxing. Better training for better results.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={productSchema} />
  </Fragment>

  <section class="bg-white px-6 md:px-12 lg:px-20 pt-28 md:pt-36 pb-20">
    <div class="max-w-[1100px] mx-auto">

      <!-- Header — tight, direct -->
      <div class="mb-10">
        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.88]">Better Training<br/>for Better Results.</h1>
        <p class="text-[#0A0A0A]/45 text-sm mt-4">Step-by-step systems built for boxing.</p>
      </div>

      <!-- 3-column product cards — bundle leads -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {products.map(p => (
          <div class={`flex flex-col group transition-colors duration-200 relative ${p.featured ? 'border-2 border-[#0057FF]/30 hover:border-[#0057FF]' : 'border border-[#0A0A0A]/10 hover:border-[#0057FF]/40'}`}>
            {p.featured && <div class="absolute top-3 left-3 z-10 bg-[#0057FF] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Best Value</div>}
            <!-- Cover image -->
            <div class={`overflow-hidden ${p.featured ? 'bg-[#0A0A0A]' : 'bg-[#F6F6F6]'}`}>
              <img src={p.image} alt={p.title}
                loading="lazy"
                class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
            </div>
            <!-- Card body -->
            <div class="p-5 flex flex-col flex-1">
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">{p.tag}</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">{p.title}</h2>
              <p class="text-[#0A0A0A]/50 text-xs mb-3 font-bold">{p.sub}</p>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed flex-1">{p.desc}</p>
              <div class="mt-5 flex items-center justify-between">
                <span class="font-black text-[#0A0A0A] text-2xl">{p.price}</span>
                <a href={p.url} target="_blank"
                  class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                  Buy Now →
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Workshop + Q&A row — live offers -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">

        <div class="border border-[#D4A373]/30 bg-[#0A0A0A] p-8 flex flex-col justify-between group hover:border-[#D4A373]/60 transition-colors duration-200">
          <div>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Live · June 27 · 90 min</p>
            <h2 class="font-black text-white uppercase tracking-tight text-2xl leading-tight mb-3">Live Mechanics Masterclass</h2>
            <p class="text-white/40 text-xs leading-relaxed">Camera on. Real-time correction on your movement. The mechanical structure to hit, exit, and reset.</p>
          </div>
          <div class="flex items-center justify-between mt-8">
            <span class="font-black text-white text-2xl">$197</span>
            <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
              class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
              Reserve Seat →
            </a>
          </div>
        </div>

        <div class="border border-[#0A0A0A]/10 bg-[#F6F6F6] flex flex-col justify-between group hover:border-[#0057FF]/30 transition-colors duration-200">
          <div class="bg-[#0A0A0A] flex items-center justify-center py-8 px-6">
            <img src="/images/trb-logo-nobg.png" alt="Mechanics Diagnostic Replay"
              class="h-20 w-auto opacity-80 group-hover:opacity-100 transition-opacity duration-300" />
          </div>
          <div class="p-8 flex flex-col flex-1 justify-between">
            <div>
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">On Demand · Full Recording</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-2xl leading-tight mb-3">Mechanics Diagnostic Replay</h2>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed">The full 90-min session. Watch the corrections. Footwork, stance, punch mechanics. Apply the framework and rewatch as many times as you need.</p>
            </div>
            <div class="flex items-center justify-between mt-8">
              <span class="font-black text-[#0A0A0A] text-2xl">$47</span>
              <a href="/workshop-replay"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                Get Replay →
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- PA strip -->
      <div class="mt-4 border border-[#6A0DAD]/20 bg-[#0A0A0A] p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 group hover:border-[#6A0DAD]/50 transition-colors duration-200">
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Application Only · 1 of 1</p>
          <h2 class="font-black text-white uppercase tracking-tight text-2xl leading-tight mb-2">Private Architecture</h2>
          <p class="text-white/35 text-xs max-w-[500px] leading-relaxed">No templates. No cohorts. A system engineered entirely around your fight, your body, your mind.</p>
        </div>
        <a href="/command"
          class="shrink-0 inline-flex items-center justify-center font-bold border-2 border-[#6A0DAD] text-[#6A0DAD] bg-transparent px-8 py-3 text-xs tracking-widest uppercase hover:bg-[#6A0DAD] hover:text-white transition-all duration-200 whitespace-nowrap">
          Apply →
        </a>
      </div>

      <!-- Start free nudge -->
      <div class="mt-10 pt-10 border-t border-[#0A0A0A]/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-[#0A0A0A]/30 text-sm">Not ready to buy? The foundation protocol is free.</p>
        <a href="/foundation-guide" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity whitespace-nowrap">Get the Free Protocol →</a>
      </div>

    </div>
  </section>

  <!-- Scripture -->
  <section class="bg-[#0A0A0A] px-6 md:px-12 lg:px-20 py-20">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] text-white/50 text-2xl md:text-3xl mb-4">
        "I do not run aimlessly. I do not box as one beating the air."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26–27</p>
    </div>
  </section>

</Layout>

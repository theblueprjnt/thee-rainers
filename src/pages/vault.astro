---
import Layout from '../layouts/Base.astro';

const products = [
  {
    image: '/images/bundle_cover.png',
    tag: 'Bundle · Best Value',
    title: 'Both Blueprints',
    sub: 'Footwork + Shadowboxing · 106 Rounds',
    desc: 'The complete system. Foundation first. Application second. Both modules running in sequence.',
    price: '$87',
    price_note: 'Save $7 vs. buying separately.',
    stripe_link: 'https://buy.stripe.com/14A4gz59hgxUaa65006J20m',
    cta: 'Get Bundle',
    featured: true,
  },
  {
    image: '/images/footworkbp_cover.png',
    tag: 'Blueprint · Module 01',
    title: 'Footwork Blueprint',
    sub: 'Module 01 · 30 Days · 56 Rounds',
    desc: 'Stance mechanics. Weight distribution. Kinetic chain from the floor up. The base layer.',
    price: '$47',
    price_note: null,
    stripe_link: 'https://buy.stripe.com/bJe14n8lt81ogyu3VW6J20k',
    cta: 'Buy Now',
    featured: false,
  },
  {
    image: '/images/shadowboxingblueprint_covernew.png',
    tag: 'Blueprint · Module 02',
    title: 'Shadowboxing Blueprint',
    sub: 'Module 02 · 6 Weeks · 40 Rounds',
    desc: 'Shadowboxing rebuilt as live simulation. Cue reading. Range fluency. Technique under pressure.',
    price: '$47',
    price_note: null,
    stripe_link: 'https://buy.stripe.com/5kQdR91X5dlIeqm8cc6J20l',
    cta: 'Buy Now',
    featured: false,
  },
];

const productSchema = JSON.stringify(products.map(p => ({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": p.title,
  "description": p.desc,
  "url": "https://theerainers.com/vault",
  "brand": { "@type": "Brand", "name": "Thee Rainers" },
  "offers": {
    "@type": "Offer",
    "price": parseFloat(p.price.replace(/[^0-9.]/g, '')),
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://theerainers.com/vault",
  },
})));
---
<Layout title="Vault — Thee Rainers" description="Step-by-step systems built for boxing. One-time purchase. Download and own it.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={productSchema} />
  </Fragment>

  <section class="bg-white px-6 md:px-12 lg:px-20 pt-28 md:pt-36 pb-20">
    <div class="max-w-[1100px] mx-auto">

      <div class="mb-10">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-3">Vault</p>
        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-4xl md:text-5xl leading-[0.88]">Better Training<br/>for Better Results.</h1>
        <p class="text-[#0A0A0A]/45 text-sm mt-4">One-time purchase. Download and own it.</p>
      </div>

      <!-- Blueprint cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {products.map(p => (
          <div class={`tr-card flex flex-col group transition-colors duration-200 relative ${p.featured ? 'border-2 border-[#0057FF]/30 hover:border-[#0057FF]' : 'border border-[#0A0A0A]/10 hover:border-[#0057FF]/40'}`}>
            {p.featured && <div class="absolute top-3 left-3 z-10 bg-[#0057FF] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Best Value</div>}
            <div class={`overflow-hidden relative ${p.featured ? 'bg-[#0A0A0A]' : 'bg-[#F6F6F6]'}`}>
              <img src={p.image} alt={p.title}
                loading="lazy"
                class="w-full object-cover aspect-[4/3] group-hover:scale-[1.02] transition-transform duration-300" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"></div>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">{p.tag}</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl leading-tight mb-1">{p.title}</h2>
              <p class="text-[#0A0A0A]/50 text-xs mb-3 font-bold">{p.sub}</p>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed flex-1">{p.desc}</p>
              <div class="mt-4 flex items-center justify-between">
                <div>
                  <span class="font-black text-[#0A0A0A] text-2xl">{p.price}</span>
                  {p.price_note && <p class="text-[10px] text-[#0A0A0A]/30 mt-0.5">{p.price_note}</p>}
                </div>
                <a href={p.stripe_link}
                  class="inline-flex items-center justify-center whitespace-nowrap bg-[#0057FF] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#0040CC] transition-colors duration-200">
                  {p.cta} →
                </a>
              </div>
              <p class="text-[11px] text-[#0A0A0A]/55 mt-2 text-right leading-relaxed">
                By purchasing you agree to our <a href="/legal/terms" class="underline hover:text-[#0A0A0A]">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]">Refund Policy</a>.
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- FAQ -->
      <div class="mt-10 pt-10 border-t border-[#0A0A0A]/8">
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-xl mb-6">Common Questions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6 max-w-[900px]">
          <div>
            <p class="font-bold text-[#0A0A0A] text-sm mb-1">How do I get access after purchase?</p>
            <p class="text-[#0A0A0A]/50 text-xs leading-relaxed">A download link is sent to the email you use at checkout. It arrives within a few minutes and is valid for 7 days. Save the PDF once downloaded.</p>
          </div>
          <div>
            <p class="font-bold text-[#0A0A0A] text-sm mb-1">Is this a subscription?</p>
            <p class="text-[#0A0A0A]/50 text-xs leading-relaxed">No. Both Blueprints are one-time purchases. Pay once, own it.</p>
          </div>
          <div>
            <p class="font-bold text-[#0A0A0A] text-sm mb-1">Can I use this without a gym?</p>
            <p class="text-[#0A0A0A]/50 text-xs leading-relaxed">Yes. The Footwork Blueprint requires no equipment. The Shadowboxing Blueprint works anywhere you have space to move.</p>
          </div>
          <div>
            <p class="font-bold text-[#0A0A0A] text-sm mb-1">What if I want live coaching alongside it?</p>
            <p class="text-[#0A0A0A]/50 text-xs leading-relaxed">The Greatness Community includes live Proving Ground sessions every week. <a href="/community" class="text-[#0057FF] font-bold hover:opacity-70 transition-opacity">Learn more.</a></p>
          </div>
        </div>
      </div>

      <!-- Workshop + Q&A row -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-10">

        <div class="border border-[#D4A373]/30 bg-[#0A0A0A] flex flex-col group hover:border-[#D4A373]/60 transition-colors duration-200">
          <div class="relative overflow-hidden" style="height: 200px;">
            <img src="/images/defense_workshop.png" alt="Defense Workshop"
              width="1920" height="1080"
              class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#0A0A0A]/45"></div>
          </div>
          <div class="p-8 flex flex-col flex-1 justify-between">
            <div>
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Live · June 27 · 90 min</p>
              <h2 class="font-black text-white uppercase tracking-tight text-2xl leading-tight mb-3">Defense Workshop</h2>
              <p class="text-white/40 text-xs leading-relaxed">Camera on. Real-time correction on your movement. The mechanical structure to hit, exit, and reset.</p>
            </div>
            <div class="flex items-center justify-between mt-8">
              <span class="font-black text-white text-2xl">$197</span>
              <div class="flex flex-col items-end gap-1">
                <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n"
                  class="inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                  Reserve Seat →
                </a>
                <p class="text-[11px] text-white/55 leading-relaxed">
                  <a href="/legal/terms" class="underline hover:text-white">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-white">Refund Policy</a>
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="border border-[#0A0A0A]/10 bg-[#F6F6F6] flex flex-col justify-between group hover:border-[#0057FF]/30 transition-colors duration-200">
          <div class="relative overflow-hidden" style="height: 200px;">
            <img src="/images/workshop_bacgkround.png" alt="Workshop Replay"
              width="1920" height="1080"
              class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#0A0A0A]/55"></div>
          </div>
          <div class="p-8 flex flex-col flex-1 justify-between">
            <div>
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">On Demand · Full Recording</p>
              <h2 class="font-black text-[#0A0A0A] uppercase tracking-tight text-2xl leading-tight mb-3">Workshop Replay</h2>
              <p class="text-[#0A0A0A]/60 text-xs leading-relaxed">The full 90-min session. Watch the corrections. Footwork, stance, punch mechanics. Apply the framework. 7-day access window from purchase.</p>
            </div>
            <div class="flex items-center justify-between mt-8">
              <span class="font-black text-[#0A0A0A] text-2xl">$79</span>
              <a href="/workshop-replay"
                class="inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-6 py-2.5 text-xs tracking-widest uppercase hover:bg-[#0057FF] hover:text-white transition-all duration-200 whitespace-nowrap">
                Get Replay →
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Community teaser -->
      <div class="mt-4 border border-[#6A0DAD]/20 bg-[#6A0DAD]/04 overflow-hidden">
        <div class="p-8 md:p-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
          <div>
            <p class="text-[#6A0DAD] text-[10px] tracking-widest uppercase mb-3">Greatness Community</p>
            <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-2xl leading-tight mb-3">Want live reps with Rainers?</h2>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed max-w-[520px]">Weekly live Proving Ground sessions with Rainers. Real-time correction on your movement. Private community chat. Drill library. $39/mo.</p>
          </div>
          <a href="/community"
            class="shrink-0 inline-flex items-center justify-center whitespace-nowrap bg-[#6A0DAD] text-white font-bold px-8 py-3 text-xs uppercase tracking-widest hover:bg-[#5a0b92] transition-colors duration-200">
            See the Community →
          </a>
        </div>
      </div>

      <!-- Start free nudge -->
      <div class="mt-10 pt-10 border-t border-[#0A0A0A]/8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-[#0A0A0A]/30 text-sm">Not ready to buy? The foundation protocol is free.</p>
        <a href="/footwork-foundation" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity whitespace-nowrap">Get the Free Protocol →</a>
      </div>

    </div>
  </section>

  <section class="bg-[#0A0A0A] px-6 md:px-12 lg:px-20 py-20">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] text-white/50 text-2xl md:text-3xl mb-4">
        "I do not run aimlessly. I do not box as one beating the air."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:26-27</p>
    </div>
  </section>

</Layout>

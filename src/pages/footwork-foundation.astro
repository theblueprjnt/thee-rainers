---
import Layout from '../layouts/Base.astro';

const stats = [
  {
    num: '76%',
    label: 'of punch power',
    detail: 'originates at the floor — not the arm. The kinetic chain starts at your feet.',
  },
  {
    num: '+24%',
    label: 'VO2 max gains',
    detail: 'in 8 weeks of structured boxing. Cardio alone does not produce this. Neither does lifting.',
  },
  {
    num: '50%',
    label: 'depression reduction',
    detail: 'in non-contact boxing trials. 2022 scoping review, University of Toronto & CAMH.',
  },
  {
    num: '17/100',
    label: 'gym members stay',
    detail: 'past 12 months. Not because they were lazy. Because fragmentation doesn\'t work.',
  },
];
---

<Layout
  title="Footwork Foundation — Free 30-Day Protocol | Thee Rainers"
  description="The foundation the gym never taught you. Four kinetic bases, 56 drill rounds, 30-day progression. Free. Download instantly."
>
  <Fragment slot="head">
    <meta property="og:title" content="Footwork Foundation — Free 30-Day Protocol | Thee Rainers" />
    <meta property="og:description" content="76% of punch power starts at the floor. Build the foundation the gym never taught you. 30-day protocol, free." />
    <meta property="og:type" content="website" />
  </Fragment>

  <!-- Mobile image strip -->
  <div class="md:hidden w-full overflow-hidden bg-[#0A0A0A]" style="height: 55vw; max-height: 320px;">
    <img src="/images/coldfightpic3.jpg" alt="Rainers — Competition"
      class="w-full h-full object-cover object-center" loading="eager" />
  </div>

  <!-- Hero -->
  <section class="bg-white overflow-hidden border-b border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-[60%_40%] md:min-h-[90vh]">

      <!-- Left: Content -->
      <div class="px-8 md:px-16 lg:px-24 pt-14 md:pt-40 pb-16 md:pb-24 flex flex-col justify-center">

        <!-- Social proof + label -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-8">
          <p class="text-[#D4A373] text-[11px] tracking-widest uppercase">Free · 30-Day Protocol</p>
          <span class="text-[#0A0A0A]/15 hidden sm:inline">·</span>
          <p class="text-[#0A0A0A]/30 text-[10px] tracking-widest uppercase">120+ fighters training</p>
        </div>

        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-3"
          style="font-size: clamp(2.5rem, 6vw, 3.5rem); line-height: 0.88;">
          The foundation<br/>the gym never<br/>taught you.
        </h1>

        <p class="text-[#0A0A0A]/20 text-[10px] tracking-widest uppercase mb-8">Rainers · Competitive Boxer · Coach</p>

        <p class="text-[#0A0A0A]/40 text-base leading-relaxed mb-10 max-w-[480px]">
          Before anything transfers, your platform has to hold. Stance. Weight distribution. Kinetic chain. 30 days to build what most fighters never had.
        </p>

        <!-- Form -->
        <div id="hero-form-wrapper">
          <form id="hero-form" class="flex flex-col sm:flex-row gap-3 max-w-[480px]">
            <input
              type="email"
              id="hero-email"
              required
              placeholder="your@email.com"
              class="flex-1 border border-[#0A0A0A]/15 bg-transparent px-5 py-4 text-[#0A0A0A] text-sm focus:border-[#0057FF] focus:outline-none transition-colors duration-200 placeholder:text-[#0A0A0A]/20"
            />
            <button
              type="submit"
              id="hero-submit"
              class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap"
            >
              Download Free →
            </button>
          </form>
          <p id="hero-success" class="hidden text-[#0057FF] text-sm tracking-wide mt-6">Your protocol is downloading — Day 1 starts when you decide.</p>
          <p id="hero-error" class="hidden text-[#0A0A0A]/40 text-sm mt-4">Something went wrong. Try again.</p>
          <p class="text-[#0A0A0A]/20 text-xs tracking-wide mt-4">Your email. Nothing else.</p>
        </div>

        <!-- Workshop anchor -->
        <div class="mt-10 pt-8 border-t border-[#0A0A0A]/8">
          <p class="text-[#0A0A0A]/20 text-[10px] tracking-widest uppercase mb-2">When you're ready</p>
          <a href="/workshop" class="text-[#0A0A0A]/35 text-xs tracking-wide hover:text-[#0057FF] transition-colors duration-200">
            The Calibration Workshop — $197 · June 27 →
          </a>
        </div>

      </div>

      <!-- Right: Fight photo — desktop only -->
      <div class="hidden md:block relative overflow-hidden">
        <img src="/images/coldfightpic3.jpg" alt="Rainers — Competition"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="eager" decoding="async" />
      </div>

    </div>
  </section>

  <!-- Research Stats -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-20 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">The Research</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[2px]">
        {stats.map(s => (
          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10">
            <p class="font-black text-[#0A0A0A] text-4xl leading-none mb-2">{s.num}</p>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">{s.label}</p>
            <p class="text-[#0A0A0A]/35 text-xs leading-relaxed">{s.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's inside: 4-Week Plan -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-24 border-t border-[#0A0A0A]/8">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">The 30-Day Plan</p>
      <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-12"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        Week by week.
      </h2>
      <div class="flex flex-col gap-0 divide-y divide-[#0A0A0A]/8">
        <div class="py-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Week 01 — Stance / Base</p>
          <p class="text-[#0A0A0A] font-bold text-sm mb-2">Master Your Position</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">10 min rhythm in stance · 10 min weight shifting · 10 min reset after punches · 10 min plank · 10 min hand positioning · 10 min slips/rolls. Stationary. No punches. Goal: stable, complete stance.</p>
        </div>
        <div class="py-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Week 02 — Footwork</p>
          <p class="text-[#0A0A0A] font-bold text-sm mb-2">Stance + Movement</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">Footwork Blueprint drills 2–4x per week. Clean reps over more reps. Stop before form breaks. Goal: move without losing position.</p>
        </div>
        <div class="py-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Week 03 — Adding Punches</p>
          <p class="text-[#0A0A0A] font-bold text-sm mb-2">Stance + Movement + Output</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">3-min rounds: 1-2 orthodox, 1-2 southpaw, 2-3 combinations. Same on bag. Use breath. Use active rest. Goal: punch while balanced.</p>
        </div>
        <div class="py-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Week 04 — Integration</p>
          <p class="text-[#0A0A0A] font-bold text-sm mb-2">Base by Default</p>
          <p class="text-[#0A0A0A]/40 text-xs leading-relaxed">1-1-2 moving left/right · 1-1-1-2-3 moving left/right. Film yourself from the side. Flow over force. Goal: base holds under fatigue — automatic.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Daily Non-Negotiable -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-24 border-t border-[#0A0A0A]/8">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">The Daily Non-Negotiable</p>
      <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-8"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        5 minutes.<br/>Every day.<br/>Even rest days.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[2px] mb-10">
        {['Stance Check', 'Engaging Feet Muscle', 'Balance Test', 'Light Shadowboxing — Emphasising Balance'].map(item => (
          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 px-6 py-4">
            <p class="text-[#0A0A0A]/50 text-xs tracking-wide">→ {item}</p>
          </div>
        ))}
      </div>
      <p class="text-[#0A0A0A]/20 text-xs leading-relaxed max-w-[480px]">
        If you miss a day — continue. Don't restart.
      </p>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="bg-white border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-[60%_40%]">

      <!-- Text -->
      <div class="px-8 md:px-16 lg:px-24 py-24">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Who this is for</p>
        <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-8"
          style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
          The 17 who stayed.<br/>And the 83 who<br/>already know why.
        </h2>
        <p class="text-[#0A0A0A]/50 text-sm leading-relaxed mb-6 max-w-[480px]">
          The gym fragments you. Weight room here. Cardio there. Mobility app on your phone. Every modality trains one piece of you in isolation — but the ring never asks you to be fit in isolation.
        </p>
        <p class="text-[#0A0A0A]/35 text-sm leading-relaxed max-w-[480px]">
          You're building an asymmetrical body with tight shoulders and no base. This fixes what most fighters take years to find — in the first week.
        </p>
      </div>

      <!-- Coaching photo -->
      <div class="hidden md:block relative overflow-hidden min-h-[400px] bg-[#0A0A0A]">
        <img src="/images/coaching-netherlands.png" alt="Rainers coaching"
          class="absolute inset-0 w-full h-full object-cover object-center opacity-90" />
      </div>

    </div>
  </section>

  <!-- Scripture -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-24 border-t border-[#D4A373]/10">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="font-black text-white/10 uppercase tracking-tighter leading-[0.88] mb-6"
        style="font-size: clamp(1.5rem, 3.5vw, 2rem);">
        "I do not run aimlessly. I do not box as one beating the air. I discipline my body and keep it under control."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-12">1 Corinthians 9:26–27</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/vault" class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
          Enter the Vault →
        </a>
        <a href="/lever-audit-quiz" class="inline-flex items-center justify-center font-bold border border-white/15 text-white/30 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-white/30 hover:text-white/60">
          Find Your Leak →
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-24 border-t border-[#0A0A0A]/8">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Access the Protocol</p>
      <h2 class="font-black text-[#0A0A0A] uppercase tracking-tighter mb-10"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        Start from<br/>the floor.
      </h2>

      <div id="footer-form-wrapper">
        <form id="footer-form" class="flex flex-col sm:flex-row gap-3 max-w-[520px]">
          <input
            type="email"
            id="footer-email"
            required
            placeholder="your@email.com"
            class="flex-1 border border-[#0A0A0A]/15 bg-transparent px-5 py-4 text-[#0A0A0A] text-sm focus:border-[#0057FF] focus:outline-none transition-colors duration-200 placeholder:text-[#0A0A0A]/20"
          />
          <button
            type="submit"
            id="footer-submit"
            class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap"
          >
            Download Free →
          </button>
        </form>
        <p id="footer-success" class="hidden text-[#0057FF] text-sm tracking-wide mt-6">Downloading now — train smart.</p>
        <p id="footer-error" class="hidden text-[#0A0A0A]/40 text-sm mt-4">Something went wrong. Try again.</p>
        <p class="text-[#0A0A0A]/20 text-xs tracking-wide mt-4">Your email. Nothing else.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  function triggerDownload(href: string, filename: string) {
    const a = document.createElement('a');
    a.href = href;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }

  function wireForm(
    formId: string,
    emailId: string,
    submitId: string,
    successId: string,
    errorId: string,
    defaultLabel: string
  ) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const submit = document.getElementById(submitId) as HTMLButtonElement | null;
    const success = document.getElementById(successId)!;
    const error = document.getElementById(errorId)!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submit) { submit.disabled = true; submit.textContent = 'Preparing...'; }
      error.classList.add('hidden');

      const email = (document.getElementById(emailId) as HTMLInputElement).value.trim();

      try {
        const res = await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'footwork-foundation', full_name: '', phone: '' }),
        });
        const body = await res.json() as { success: boolean };
        if (body.success) {
          form?.classList.add('hidden');
          success.classList.remove('hidden');
          triggerDownload('/pdfs/footwork-foundation.pdf', 'Footwork-Foundation-Thee-Rainers.pdf');
        } else { throw new Error(); }
      } catch {
        error.classList.remove('hidden');
        if (submit) { submit.disabled = false; submit.textContent = defaultLabel; }
      }
    });
  }

  wireForm('hero-form', 'hero-email', 'hero-submit', 'hero-success', 'hero-error', 'Download Free →');
  wireForm('footer-form', 'footer-email', 'footer-submit', 'footer-success', 'footer-error', 'Download Free →');

  const params = new URLSearchParams(window.location.search);
  if (params.get('error')) {
    const el = document.getElementById('hero-error');
    if (el) { el.textContent = 'Something went wrong. Try again.'; el.classList.remove('hidden'); }
  }
</script>

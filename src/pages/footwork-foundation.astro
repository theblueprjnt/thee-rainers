---
import Layout from '../layouts/Base.astro';

const stats = [
  {
    num: '76%',
    label: 'of punch power',
    detail: 'originates at the floor — not the arm. The kinetic chain starts at your feet.',
  },
  {
    num: '+24%',
    label: 'VO2 max gains',
    detail: 'in 8 weeks of structured boxing. Cardio alone does not produce this. Neither does lifting.',
  },
  {
    num: '50%',
    label: 'depression reduction',
    detail: 'in non-contact boxing trials. 2022 scoping review, University of Toronto & CAMH.',
  },
  {
    num: '17/100',
    label: 'gym members stay',
    detail: 'past 12 months. Not because they were lazy. Because fragmentation doesn\'t work.',
  },
];
---

<Layout
  title="Footwork Protocol — System Baseline | Thee Rainers"
  description="The foundation the gym never taught you. Four kinetic bases, 56 drill rounds, 30-day progression. Free. Autonomic regulation begins here."
>
  <Fragment slot="head">
    <meta property="og:title" content="Footwork Protocol — System Baseline | Thee Rainers" />
    <meta property="og:description" content="The foundation the gym never taught you. 76% of punch power starts at the floor. Four kinetic bases, 56 drill rounds, 30-day progression. Free." />
    <meta property="og:type" content="website" />
  </Fragment>

  <!-- Hero -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 pt-32 md:pt-40 pb-24">
    <div class="max-w-[720px] mx-auto w-full">

      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-8">Free · System Baseline</p>
      <h1 class="font-black text-white uppercase tracking-tighter mb-6"
        style="font-size: clamp(2.5rem, 6vw, 3.5rem); line-height: 0.88;">
        The foundation<br/>the gym never<br/>taught you.
      </h1>
      <p class="text-white/40 text-base leading-relaxed mb-12 max-w-[520px]">
        Four kinetic bases. 56 drill rounds. 30-day progression. This is not a workout guide — it is the mechanical platform that everything else runs on. Free.
      </p>

      <!-- Inline form -->
      <div id="hero-form-wrapper">
        <form id="hero-form" class="flex flex-col sm:flex-row gap-3 max-w-[520px]">
          <input
            type="email"
            id="hero-email"
            required
            placeholder="your@email.com"
            class="flex-1 border border-white/15 bg-transparent px-5 py-4 text-white text-sm focus:border-[#D4A373] focus:outline-none transition-colors duration-200 placeholder:text-white/20"
          />
          <button
            type="submit"
            id="hero-submit"
            class="copper-btn inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#D4A373] hover:text-black whitespace-nowrap"
          >
            Send the Guide →
          </button>
        </form>
        <p id="hero-success" class="hidden text-[#D4A373] text-sm tracking-wide mt-6">The guide is in your inbox.</p>
        <p id="hero-error" class="hidden text-white/40 text-sm mt-4">Something went wrong. Try again.</p>
        <p class="text-white/20 text-xs tracking-wide mt-4">No spam. Unsubscribe anytime.</p>
      </div>

    </div>
  </section>

  <!-- Research Stats from the video -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-20 border-t border-white/5">
    <div class="max-w-[1280px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">The Research</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-[2px]">
        {stats.map(s => (
          <div class="bg-[#111111] border border-white/5 p-10">
            <p class="font-black text-white text-4xl leading-none mb-2">{s.num}</p>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">{s.label}</p>
            <p class="text-white/35 text-xs leading-relaxed">{s.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's inside -->
  <section class="bg-[#0D0D0D] px-8 md:px-16 lg:px-24 py-24 border-t border-white/5">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">System Architecture</p>
      <h2 class="font-black text-white uppercase tracking-tighter mb-12"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        What is inside.
      </h2>
      <div class="flex flex-col gap-10">
        <div class="border-t border-white/5 pt-10">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Layer 01 — Kinetic Bases</p>
          <p class="text-white/50 text-sm leading-relaxed">Four bases. Steps. Galloping. Pivoting. Pendulum. Each one a mechanical input that trains the nervous system to generate floor-up power without cognitive overhead. 76% of your output begins here.</p>
        </div>
        <div class="border-t border-white/5 pt-10">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Layer 02 — Drill Rounds</p>
          <p class="text-white/50 text-sm leading-relaxed">56 structured rounds organized by distance management, angle creation, and exit lines. Usable for solo training, gym warmups, and mechanical correction. No partner required.</p>
        </div>
        <div class="border-t border-white/5 pt-10">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Layer 03 — Progression Structure</p>
          <p class="text-white/50 text-sm leading-relaxed">30-day sequencing that builds kinetic integrity before layering complexity. The system does not skip foundations. Most fighters spend years fixing what this protocol installs in the first week.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who this is for -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-24 border-t border-white/5">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Who this is for</p>
      <h2 class="font-black text-white uppercase tracking-tighter mb-8"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        The 17 who stayed.<br/>And the 83 who<br/>already know why.
      </h2>
      <p class="text-white/50 text-sm leading-relaxed mb-6 max-w-[560px]">
        The gym fragments you. Weight room here. Cardio there. Mobility app on your phone. Every modality trains one piece of you in isolation — but life never asks you to be fit in isolation.
      </p>
      <p class="text-white/35 text-sm leading-relaxed max-w-[560px]">
        This protocol is for the fighter who already understood that working harder on the wrong foundation produces more of the same. The foundation is the fix. Start here.
      </p>
    </div>
  </section>

  <!-- Scripture -->
  <section class="bg-[#0D1F1F] px-8 md:px-16 lg:px-24 py-24 border-t border-[#D4A373]/10">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="font-black text-white/10 uppercase tracking-tighter leading-[0.88] mb-6"
        style="font-size: clamp(1.5rem, 3.5vw, 2rem);">
        "I do not run aimlessly. I do not box as one beating the air. I discipline my body and keep it under control."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-12">1 Corinthians 9:26–27</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/vault" class="copper-btn inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#D4A373] hover:text-black">
          Enter the Vault →
        </a>
        <a href="/lever-audit" class="inline-flex items-center justify-center font-bold border border-white/15 text-white/30 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-white/30 hover:text-white/50">
          Find Your Leak →
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-[#0A0A0A] px-8 md:px-16 lg:px-24 py-24 border-t border-white/5">
    <div class="max-w-[720px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Access the Protocol</p>
      <h2 class="font-black text-white uppercase tracking-tighter mb-10"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); line-height: 0.9;">
        Start from<br/>the floor.
      </h2>

      <div id="footer-form-wrapper">
        <form id="footer-form" class="flex flex-col sm:flex-row gap-3 max-w-[520px]">
          <input
            type="email"
            id="footer-email"
            required
            placeholder="your@email.com"
            class="flex-1 border border-white/15 bg-transparent px-5 py-4 text-white text-sm focus:border-[#D4A373] focus:outline-none transition-colors duration-200 placeholder:text-white/20"
          />
          <button
            type="submit"
            id="footer-submit"
            class="copper-btn inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#D4A373] hover:text-black whitespace-nowrap"
          >
            Access the Protocol →
          </button>
        </form>
        <p id="footer-success" class="hidden text-[#D4A373] text-sm tracking-wide mt-6">The protocol is in your inbox.</p>
        <p id="footer-error" class="hidden text-white/40 text-sm mt-4">Something went wrong. Try again.</p>
        <p class="text-white/20 text-xs tracking-wide mt-4">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  function wireForm(formId: string, emailId: string, submitId: string, successId: string, errorId: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const submit = document.getElementById(submitId) as HTMLButtonElement | null;
    const success = document.getElementById(successId)!;
    const error = document.getElementById(errorId)!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submit) { submit.disabled = true; submit.textContent = 'Sending...'; }
      error.classList.add('hidden');

      const email = (document.getElementById(emailId) as HTMLInputElement).value.trim();

      try {
        const res = await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'footwork-foundation', full_name: '', phone: '' }),
        });
        const body = await res.json() as { success: boolean };
        if (body.success) {
          form?.classList.add('hidden');
          success.classList.remove('hidden');
        } else { throw new Error(); }
      } catch {
        error.classList.remove('hidden');
        if (submit) { submit.disabled = false; submit.textContent = 'Send the Guide →'; }
      }
    });
  }

  wireForm('hero-form', 'hero-email', 'hero-submit', 'hero-success', 'hero-error');
  wireForm('footer-form', 'footer-email', 'footer-submit', 'footer-success', 'footer-error');

  // Show error from redirect fallback
  const params = new URLSearchParams(window.location.search);
  const errorCode = params.get('error');
  if (errorCode) {
    const el = document.getElementById('hero-error');
    if (el) { el.textContent = 'Something went wrong. Try again.'; el.classList.remove('hidden'); }
  }
</script>

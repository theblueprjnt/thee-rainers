---
// PDF is served from /pdfs/footwork-foundation.pdf
// Replace public/pdfs/footwork-foundation.pdf with the real file before launch.
import Base from '../layouts/Base.astro';
import Container from '../components/primitives/Container.astro';
import Section from '../components/primitives/Section.astro';
import Rule from '../components/primitives/Rule.astro';
import Pill from '../components/primitives/Pill.astro';
import LeadForm from '../components/blocks/LeadForm.astro';
---

<Base
  title="System Baseline — Footwork Protocol | Thee Rainers"
  description="The kinetic foundation of the system. Four bases, 56 drill rounds, 30-day progression. Autonomic regulation begins here. Free."
>
  <Fragment slot="head">
    <meta property="og:title" content="System Baseline — Footwork Protocol | Thee Rainers" />
    <meta property="og:description" content="The kinetic foundation of the system. Four bases, 56 drill rounds, 30-day progression. Autonomic regulation begins here. Free." />
    <meta property="og:image" content="/og-footwork-foundation.jpg" />
    <meta property="og:type" content="website" />
  </Fragment>

  <!-- ── 1. Hero ─────────────────────────────────────────────────── -->
  <section class="bg-[#0A0A0A] pt-36 pb-20 md:pt-44 md:pb-28">
    <Container size="prose">
      <div class="mb-6">
        <Pill>Free · System Baseline</Pill>
      </div>

      <h1
        class="font-black text-white uppercase tracking-tighter mb-5"
        style="font-size: clamp(2.25rem, 5.5vw, 3rem); line-height: 0.9;"
      >
        Footwork Protocol:<br/>System Baseline.
      </h1>

      <p
        class="text-white/40 leading-[1.55] mb-10 max-w-[520px]"
        style="font-size: var(--font-size-body);"
      >
        Autonomic regulation begins at the floor. Four kinetic bases, 56 drill rounds,
        30-day progression structure. This is not a workout guide —
        it is the foundation layer of the system.
      </p>

      <LeadForm id="hero-form" />

      <p class="text-white/25 mt-4 m-0" style="font-size: var(--font-size-small);">
        No spam. Unsubscribe anytime.
      </p>
    </Container>
  </section>

  <!-- ── 2. System Architecture ────────────────────────────────── -->
  <Section padding="lg" class="bg-[#0D0D0D]">
    <Container size="prose">
      <div class="border-t border-white/5 pt-12 mb-12"></div>
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">System Architecture</p>
      <h2
        class="font-black text-white uppercase tracking-tighter mb-10"
        style="font-size: var(--font-size-h2); line-height: 0.9;"
      >
        What is inside.
      </h2>
      <div class="flex flex-col gap-8">
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Layer 01 — Kinetic Bases</p>
          <p class="text-white/50 leading-[1.6]" style="font-size: var(--font-size-body);">
            Four bases. Steps. Galloping. Pivoting. Pendulum. Each one a mechanical input that trains the nervous system to generate floor-up power without cognitive overhead.
          </p>
        </div>
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Layer 02 — Drill Rounds</p>
          <p class="text-white/50 leading-[1.6]" style="font-size: var(--font-size-body);">
            56 structured rounds organized by distance management, angle creation, and exit lines. Usable for solo training, gym warmups, and mechanical correction.
          </p>
        </div>
        <div>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-2">Layer 03 — Progression Structure</p>
          <p class="text-white/50 leading-[1.6]" style="font-size: var(--font-size-body);">
            30-day sequencing that builds kinetic integrity before layering complexity. The system does not skip foundations. Neither should the fighter.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  <!-- ── 3. Qualification ──────────────────────────────────────── -->
  <Section padding="lg" class="bg-[#0A0A0A]">
    <Container size="prose">
      <div class="border-t border-white/5 pt-12 mb-12"></div>
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Who this is for</p>
      <h2
        class="font-black text-white uppercase tracking-tighter mb-8"
        style="font-size: var(--font-size-h2); line-height: 0.9;"
      >
        System builders.<br/>Not fitness consumers.
      </h2>
      <p class="text-white/50 leading-[1.6]" style="font-size: var(--font-size-body);">
        Fighters whose mechanics fragment under pressure. Athletes who train volume
        but feel the kinetic chain disconnect in sparring. Coaches who want a structure
        that is repeatable, measurable, and not dependent on motivation.
        Anyone who has already understood that working harder is not the cure.
      </p>
    </Container>
  </Section>

  <!-- ── 4. Integration ────────────────────────────────────────── -->
  <Section padding="lg" class="bg-[#0D0D0D]">
    <Container size="prose">
      <div class="border-t border-white/5 pt-12 mb-12"></div>
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">System Integration</p>
      <h2
        class="font-black text-white uppercase tracking-tighter mb-8"
        style="font-size: var(--font-size-h2); line-height: 0.9;"
      >
        The loop.
      </h2>
      <p class="text-white/50 leading-[1.6] mb-10" style="font-size: var(--font-size-body);">
        Everyone who downloads the protocol is invited to the monthly live Q&A session.
        One hour. One Saturday per month. Unfiltered questions, no upsell.
        The protocol is the entry point. The loop is where the system compounds.
      </p>
      <a href="/qa" class="copper-btn inline-flex items-center justify-center font-bold border-2 border-[#D4A373] text-[#D4A373] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#D4A373] hover:text-black">
        Join the Monthly Q&A →
      </a>
    </Container>
  </Section>

  <!-- ── 5. Final CTA ───────────────────────────────────────────── -->
  <Section padding="lg" class="bg-[#0A0A0A]">
    <Container size="prose">
      <div class="border-t border-white/5 pt-12 mb-12"></div>
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Initialize</p>
      <h2
        class="font-black text-white uppercase tracking-tighter mb-8"
        style="font-size: var(--font-size-h2); line-height: 0.9;"
      >
        Access the protocol.
      </h2>
      <LeadForm id="footer-form" submitText="Access the Protocol" />
      <p class="text-white/25 mt-4 m-0" style="font-size: var(--font-size-small);">
        No spam. Unsubscribe anytime.
      </p>
    </Container>
  </Section>
</Base>

<script>
  // Show inline error banner if redirected back with ?error= query param (no-JS failure path).
  const params = new URLSearchParams(window.location.search);
  const errorCode = params.get('error');
  if (errorCode) {
    const messages: Record<string, string> = {
      invalid_email: 'Please enter a valid email address.',
      delivery_failed: 'Delivery failed. Please try again.',
      bad_request: 'Something went wrong. Please try again.',
    };
    const msg = messages[errorCode] || 'Something went wrong. Please try again.';
    const errorEl = document.querySelector<HTMLElement>('[data-lead-error]');
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }
  }
</script>

---
import Layout from '../../layouts/Base.astro';
---
<Layout
  title="Greatness Community — Thee Rainers"
  description="Monthly live Proving Ground sessions with Rainers. Real-time movement correction. The room where the work gets pressure-tested."
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
  </Fragment>

  <!-- Hero -->
  <section class="bg-white overflow-hidden border-b border-[#0A0A0A]/8">
    <div class="md:hidden w-full overflow-hidden bg-[#0A0A0A]" style="height: 60vw; max-height: 340px;">
      <img
        src="/images/sparring_withnetherlands.png"
        alt="Proving Ground — live session with Rainers"
        width="1200" height="1500"
        loading="eager"
        class="w-full h-full object-cover object-top"
      />
    </div>

    <div class="max-w-[1140px] mx-auto px-6 md:px-12 lg:px-20">
      <div class="grid grid-cols-1 md:grid-cols-[60fr_40fr] min-h-[600px]">

        <div class="flex flex-col justify-center py-20 md:py-32 md:pr-16">
          <p class="text-[#6A0DAD] text-[11px] tracking-widest uppercase mb-6">Greatness Community</p>
          <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter leading-[0.85] mb-6"
            style="font-size: clamp(2.8rem, 5.5vw, 4.5rem);">
            The room where<br/>the work gets<br/>pressure-tested.
          </h1>
          <p class="text-[#0A0A0A]/55 text-base leading-relaxed mb-10 max-w-[480px]">
            Monthly live Proving Ground sessions. Camera on. Real-time correction on your movement, stance, and angles. Blueprints give you the system. The Community is where you run it under pressure.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <button data-checkout="greatness_monthly"
              class="inline-flex items-center justify-center whitespace-nowrap disabled:opacity-40 bg-[#6A0DAD] text-white font-bold px-8 py-4 text-xs uppercase tracking-widest hover:bg-[#5a0b92] transition-colors duration-200 cursor-pointer border-0">
              Join Monthly — $39/mo →
            </button>
            <button data-checkout="greatness_annual"
              class="inline-flex items-center justify-center whitespace-nowrap disabled:opacity-40 border-2 border-[#6A0DAD] text-[#6A0DAD] bg-transparent font-bold px-8 py-4 text-xs uppercase tracking-widest hover:bg-[#6A0DAD] hover:text-white transition-all duration-200 cursor-pointer">
              Join Annual — $390/yr
            </button>
          </div>

          <p class="text-[10px] text-[#0A0A0A]/30 leading-relaxed">
            Cancel anytime. By joining you agree to our <a href="/legal/terms" class="underline hover:text-[#0A0A0A]/60">Terms</a> &amp; <a href="/legal/refund-policy" class="underline hover:text-[#0A0A0A]/60">Refund Policy</a>.
          </p>
        </div>

        <div class="hidden md:block relative overflow-hidden bg-[#0A0A0A]">
          <img
            src="/images/sparring_withnetherlands.png"
            alt="Proving Ground — live session"
            width="1200" height="1500"
            loading="eager"
            class="absolute inset-0 w-full h-full object-cover object-top opacity-80"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-20 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1100px] mx-auto">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">What's Included</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[#0A0A0A]/8">

        <div class="bg-white p-8">
          <p class="text-[#6A0DAD] text-[10px] tracking-widest uppercase mb-4">Monthly</p>
          <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-lg leading-tight mb-3">The Proving Ground</h3>
          <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Live session every month. Camera on. Rainers reviews your movement in real time. One correction in a live room hits different than ten in a PDF.</p>
        </div>

        <div class="bg-white p-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Always On</p>
          <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-lg leading-tight mb-3">Drill Library Access</h3>
          <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Full access to the structured drill archive. Every session is categorized by lever — footwork, shadowboxing, defense, perception. Work what's weak.</p>
        </div>

        <div class="bg-white p-8">
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Growing</p>
          <h3 class="font-black text-[#0A0A0A] uppercase tracking-tight text-lg leading-tight mb-3">Session Archive</h3>
          <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Every Proving Ground recorded and filed. Miss a session or want to rewatch a correction — it's there. The archive grows every month you're in.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-[#F6F6F6] px-6 md:px-12 lg:px-20 py-20 border-b border-[#0A0A0A]/8">
    <div class="max-w-[800px] mx-auto">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Membership</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <div class="bg-white border border-[#0A0A0A]/10 p-8 flex flex-col justify-between">
          <div>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Monthly</p>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="font-black text-[#0A0A0A] text-4xl">$39</span>
              <span class="text-[#0A0A0A]/40 text-sm">/mo</span>
            </div>
            <p class="text-[#0A0A0A]/40 text-xs mb-8">Cancel anytime before your next renewal.</p>
          </div>
          <button data-checkout="greatness_monthly"
            class="inline-flex items-center justify-center whitespace-nowrap disabled:opacity-40 bg-[#6A0DAD] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#5a0b92] transition-colors duration-200 cursor-pointer border-0 w-full">
            Join Monthly →
          </button>
        </div>

        <div class="bg-white border-2 border-[#6A0DAD]/30 p-8 flex flex-col justify-between relative">
          <div class="absolute top-3 right-3 bg-[#6A0DAD] text-white text-[9px] font-bold tracking-widest uppercase px-2 py-1">Save $78</div>
          <div>
            <p class="text-[#6A0DAD] text-[10px] tracking-widest uppercase mb-4">Annual</p>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="font-black text-[#0A0A0A] text-4xl">$390</span>
              <span class="text-[#0A0A0A]/40 text-sm">/yr</span>
            </div>
            <p class="text-[#0A0A0A]/40 text-xs mb-8">Equivalent to $32.50/mo. Billed once annually.</p>
          </div>
          <button data-checkout="greatness_annual"
            class="inline-flex items-center justify-center whitespace-nowrap disabled:opacity-40 bg-[#6A0DAD] text-white font-bold px-6 py-3 text-xs uppercase tracking-widest hover:bg-[#5a0b92] transition-colors duration-200 cursor-pointer border-0 w-full">
            Join Annual →
          </button>
        </div>

      </div>
    </div>
  </section>

  <!-- Already a member -->
  <section class="bg-white px-6 md:px-12 lg:px-20 py-16 border-b border-[#0A0A0A]/8">
    <div class="max-w-[600px] mx-auto text-center">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-3">Already a Member?</p>
      <a href="/community/inside"
        class="inline-flex items-center justify-center font-bold text-[#6A0DAD] text-xs tracking-widest uppercase border-2 border-[#6A0DAD] px-8 py-3 hover:bg-[#6A0DAD] hover:text-white transition-all duration-200">
        Enter Member Area →
      </a>
    </div>
  </section>

  <!-- Scripture -->
  <section class="bg-[#0A0A0A] px-6 md:px-12 lg:px-20 py-20">
    <div class="max-w-[680px] mx-auto">
      <p class="font-black uppercase tracking-tighter leading-[0.88] text-white/50 text-2xl md:text-3xl mb-4">
        "As iron sharpens iron, so one person sharpens another."
      </p>
      <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">Proverbs 27:17</p>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-checkout]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const key = btn.dataset.checkout;
      const originalHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<svg class="animate-spin h-4 w-4 mr-2 inline" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg> Processing...';
      btn.classList.add('opacity-80', 'cursor-not-allowed');
      try {
        const res = await fetch('/api/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ lookupKey: key }),
        });
        const data = await res.json() as { url?: string };
        if (data.url) {
          window.location.href = data.url;
        } else {
          btn.disabled = false;
          btn.innerHTML = originalHTML;
          btn.classList.remove('opacity-80', 'cursor-not-allowed');
        }
      } catch {
        btn.disabled = false;
        btn.innerHTML = originalHTML;
        btn.classList.remove('opacity-80', 'cursor-not-allowed');
      }
    });
  });
</script>

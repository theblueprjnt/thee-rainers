---
import Layout from '../layouts/Base.astro';

const faqItems = [
  {
    question: "I shadowbox a lot but it does not transfer in sparring. Will this help?",
    answer: "Yes. The most common reason is that your stance breaks without you noticing. The Calibration trains the awareness and the mechanical foundation that makes shadowboxing build real skill.",
  },
  {
    question: "I have been training for years. Will this be too basic?",
    answer: "If you can tell me exactly when your heel drops, where your weight transfers in a hook, and why your chain disconnects under fatigue — this is too basic. Most fighters with five plus years cannot. This fills the gap.",
  },
  {
    question: "I have a fight coming up. Will I be able to apply this in time?",
    answer: "Fighters with matches inside 30 days have applied the framework in their next sparring round. First pass gives you the mental model. Every pass after that deepens the pattern.",
  },
  {
    question: "I cannot attend live. Will it be recorded?",
    answer: "Yes. Full recording within 24 hours. Live is preferred — real-time correction only happens live. The recording lets you re-run the framework as many times as you need.",
  },
  {
    question: "Can I get a refund?",
    answer: "Yes. Email rainers@stepintoring.com within 24 hours of the session ending and I return your money. No friction. No forms. No questions.",
  },
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
});
---

<Layout title="Live Mechanics Masterclass — Workshop | Thee Rainers">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqSchema} />
    <meta name="description" content="90 minutes. The mechanical structure to hit, exit, and reset. Saturday, June 27. $197." />
  </Fragment>

  <section class="min-h-screen bg-white px-8 md:px-16 lg:px-24 py-32 md:py-40">
    <div class="max-w-[1280px] mx-auto w-full">

      <div class="mb-16">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Live Workshop · Saturday, June 27</p>
        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-5xl md:text-7xl leading-[0.8] mb-8">Live Mechanics<br/>Masterclass.</h1>
        <p class="text-[#0A0A0A]/40 text-base max-w-[480px] leading-relaxed">90 minutes. The mechanical structure to hit, exit, and reset. Live, with real-time correction on your actual movement.</p>
      </div>

      <!-- 60/40 Product Grid -->
      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-[2px]">

        <!-- Left 60%: The Workshop — Flagship -->
        <div class="bg-[#0D1F1F] border border-[#D4A373]/20 hover:border-[#D4A373]/55 transition-colors duration-300 p-12 md:p-16 flex flex-col justify-between min-h-[540px] group">
          <div>
            <span class="text-[#D4A373] text-[11px] tracking-widest uppercase">One Session · Reusable Framework</span>
            <h2 class="font-black text-white uppercase tracking-tighter mt-4 mb-6 text-3xl md:text-4xl leading-[0.85]">Live Mechanics<br/>Masterclass</h2>
            <p class="text-white/55 text-sm leading-relaxed max-w-[380px] mb-10">Foot Space Work: single-leg balance, weight transfer, kinetic chain alignment, stance. The mechanics your gym doesn't teach — live, corrected in real time. You run this framework again and again.</p>
            <div class="flex flex-col gap-3">
              <p class="text-white/30 text-[10px] tracking-widest uppercase mb-2">Session Structure</p>
              <p class="text-white/50 text-sm">— Foundation (30 min): the four mechanical bases</p>
              <p class="text-white/50 text-sm">— Application (45 min): live drilling, camera on, real-time correction</p>
              <p class="text-white/50 text-sm">— Integration (15 min): your 30-day written progression</p>
              <p class="text-[#D4A373] text-sm">— Full recording delivered within 24 hours</p>
            </div>
          </div>
          <div class="mt-12">
            <p class="text-white/25 text-[10px] tracking-widest uppercase mb-5">Limited seats · Saturday, June 27</p>
            <div class="flex items-center justify-between">
              <span class="text-white font-black text-4xl">$197</span>
              <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
                Reserve Your Seat →
              </a>
            </div>
          </div>
        </div>

        <!-- Right 40%: Context stacked -->
        <div class="flex flex-col gap-[2px]">

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Who this is for</p>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Fighters whose ambition is ahead of their gym. Competitive amateurs, coaches, and serious athletes who want structural understanding — not more conditioning.</p>
          </div>

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">The Composure Guarantee</p>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Show up, do the work. If you don't walk away with a clear framework, email rainers@stepintoring.com within 24 hours. Full refund. No questions.</p>
          </div>

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#0A0A0A]/20 text-xs leading-relaxed italic mb-4">"I discipline my body and keep it under control."</p>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:27</p>
          </div>

        </div>
      </div>

      <!-- Testimonial -->
      <div class="mt-20 border-t border-[#0A0A0A]/8 pt-16">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">What fighters say</p>
        <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-[2px]">

          <!-- Video -->
          <div class="aspect-video bg-[#0A0A0A]">
            <iframe
              src="https://www.youtube.com/embed/VCj0Dgfoako"
              title="Giancarlo — Thee Rainers Workshop"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>

          <!-- Quote -->
          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex flex-col justify-between">
            <div>
              <p class="text-[#0A0A0A]/70 text-base leading-relaxed font-bold mb-6">
                "The structure that was missing from my entire training."
              </p>
              <p class="text-[#0A0A0A]/40 text-sm leading-relaxed">
                Real-time correction on live movement. Not theory — the actual mechanical gaps showing up in sparring, addressed in the session.
              </p>
            </div>
            <div class="mt-8 pt-8 border-t border-[#0A0A0A]/8">
              <p class="text-[#0A0A0A]/60 text-sm font-bold">Giancarlo</p>
              <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mt-1">Workshop Attendee</p>
            </div>
          </div>

        </div>
      </div>

      <!-- FAQ -->
      <div class="mt-20 border-t border-[#0A0A0A]/8 pt-16">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">Questions</p>
        <div class="flex flex-col divide-y divide-[#0A0A0A]/8 max-w-[720px]">
          {faqItems.map((item) => (
            <details class="group py-8 cursor-pointer">
              <summary class="font-bold text-[#0A0A0A]/60 text-sm tracking-wide list-none flex items-center justify-between gap-8 hover:text-[#0A0A0A] transition-colors duration-200">
                {item.question}
                <span class="text-[#D4A373] shrink-0 text-lg leading-none group-open:rotate-45 transition-transform duration-200">+</span>
              </summary>
              <p class="text-[#0A0A0A]/35 text-sm leading-relaxed mt-6">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Not ready? Down-path -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-12 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full flex flex-col sm:flex-row items-center justify-between gap-6">
      <p class="text-[#0A0A0A]/30 text-sm">Not ready for live? Start with the free 30-day protocol first.</p>
      <div class="flex gap-4 shrink-0">
        <a href="/footwork-foundation" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity">Get Free Protocol →</a>
        <a href="/vault" class="text-[#0A0A0A]/30 text-xs font-bold tracking-widest uppercase hover:text-[#0A0A0A]/60 transition-colors">See All Products →</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-24 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full flex flex-col md:flex-row items-start md:items-end justify-between gap-12">
      <div>
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">One session. The mechanics start here.</p>
        <h2 class="font-black text-[#0A0A0A]/10 uppercase tracking-tighter text-3xl md:text-4xl leading-[0.9] max-w-[560px]">"I do not run aimlessly. I do not box as one beating the air."</h2>
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mt-4">1 Corinthians 9:26</p>
      </div>
      <div class="flex flex-col gap-4 shrink-0">
        <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
          class="copper-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white">
          Reserve Your Seat — $197 →
        </a>
        <a href="/vault"
          class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/15 text-[#0A0A0A]/30 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/50">
          Browse the Vault →
        </a>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Base.astro';
import { Picture } from 'astro:assets';
import defenseCover1 from '../assets/defense_cover1.jpg';

const faqItems = [
  {
    question: "I shadowbox a lot but it does not transfer in sparring. Will this help?",
    answer: "Yes. The most common reason is that your stance breaks without you noticing. The Defense Workshop builds the awareness and the mechanical foundation that makes shadowboxing transfer to real boxing.",
  },
  {
    question: "I have been training for years. Will this be too basic?",
    answer: "If you can tell me exactly when your heel drops, where your weight transfers in a hook, and why your chain disconnects under fatigue — this is too basic. Most fighters with five plus years cannot. This fills the gap.",
  },
  {
    question: "I have a fight coming up. Will I be able to apply this in time?",
    answer: "Fighters with matches inside 30 days have applied the framework in their next sparring round. First pass gives you the mental model. Every pass after that deepens the pattern.",
  },
  {
    question: "I cannot attend live. Will it be recorded?",
    answer: "Yes. Full recording within 24 hours. Live is preferred — real-time correction only happens live. The recording lets you re-run the framework as many times as you need.",
  },
  {
    question: "Can I get a refund?",
    answer: "Yes. Email rainers@theerainers.com within 24 hours of the session ending and I return your money. No friction. No forms. No questions.",
  },
];

const eventSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Defense Workshop",
  "description": "90 minutes. Camera on. Real-time correction on your defensive structure, movement patterns, and mechanical foundation.",
  "startDate": "2026-06-27", // TODO: POST-JUNE-27 DATE SWAP
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": { "@type": "VirtualLocation", "url": "https://theerainers.com/workshop" },
  "organizer": { "@type": "Organization", "name": "Thee Rainers", "url": "https://theerainers.com" },
  "offers": {
    "@type": "Offer",
    "price": "197",
    "priceCurrency": "USD",
    "url": "https://buy.stripe.com/7sY28r8lt1D06XU6446J20n",
    "availability": "https://schema.org/InStock"
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
});
---

<Layout title="Defense Workshop — Thee Rainers">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={eventSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
    <!-- TODO: POST-JUNE-27 DATE SWAP — update both meta tags below -->
    <meta name="description" content="90 minutes. Camera on. Real-time correction on your defensive structure, movement, and mechanics. Saturday, June 27. $197." />
    <meta property="og:title" content="Defense Workshop — Thee Rainers" />
    <meta property="og:description" content="90 minutes. Camera on. Real-time correction on your defensive structure. Saturday, June 27. $197." />
    <meta property="og:type" content="website" />
  </Fragment>

  <!-- HERO: 60/40 — defense_cover above the fold -->
  <section class="bg-white overflow-hidden border-b border-[#0A0A0A]/8">

    <!-- Mobile image strip -->
    <div class="md:hidden w-full overflow-hidden bg-[#0D1F1F]" style="height: 65vw; max-height: 360px;">
      <img
        src="/images/sparring-netherlands.png"
        alt="Defense Workshop — live boxing sparring session"
        width="1920" height="1080"
        loading="eager"
        fetchpriority="high"
        class="w-full h-full object-cover object-top"
      />
    </div>

    <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-[60%_40%] md:min-h-[90vh]">

      <!-- Left 60%: Content -->
      <div class="px-8 md:px-16 lg:px-24 pt-14 md:pt-40 pb-12 md:pb-16 flex flex-col justify-center">
        <!-- TODO: POST-JUNE-27 DATE SWAP -->
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-6">Live · June 27 · 90 Min · <span id="workshop-countdown" class="tabular-nums"></span></p>
        <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter text-5xl md:text-7xl leading-[0.8] mb-8">The Defense<br/>Workshop.</h1>
        <p class="text-[#0A0A0A]/60 text-base max-w-[480px] leading-relaxed mb-10">Camera on. Real-time correction on your defensive structure, movement patterns, and mechanical foundation. You leave with a framework you run again and again.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
            class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap">
            Reserve Your Seat — $197 →
          </a>
          <a href="/workshop-replay"
            class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/15 text-[#0A0A0A]/40 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/60 whitespace-nowrap">
            Get the Replay — $79 →
          </a>
        </div>
      </div>

      <!-- Right 40%: sparring photo — desktop only -->
      <div class="hidden md:block relative overflow-hidden bg-[#0D1F1F]">
        <img
          src="/images/sparring-netherlands.png"
          alt="Defense Workshop — live boxing sparring session"
          width="1920" height="1080"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 w-full h-full object-cover object-top"
        />
      </div>

    </div>
  </section>

  <!-- PRODUCT CARD -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-20 border-b border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full">
      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] gap-[2px]">

        <!-- Left 60%: Workshop — Flagship -->
        <div class="bg-[#0D1F1F] border border-[#D4A373]/20 hover:border-[#D4A373]/55 transition-colors duration-300 p-12 md:p-16 flex flex-col justify-between min-h-[540px] group">
          <div>
            <span class="text-[#D4A373] text-[10px] tracking-wider md:tracking-widest uppercase">One Session · Reusable Framework</span>
            <h2 class="font-black text-white uppercase tracking-tighter mt-4 mb-6 text-3xl md:text-4xl leading-[0.85]">Defense<br/>Workshop</h2>
            <p class="text-white/55 text-sm leading-relaxed max-w-[380px] mb-10">Foot Space Work: single-leg balance, weight transfer, kinetic chain alignment, defensive structure. The mechanics your gym doesn't teach — live, corrected in real time. You run this framework again and again.</p>
            <div class="flex flex-col gap-3">
              <p class="text-white/30 text-[10px] tracking-widest uppercase mb-2">Session Structure</p>
              <ul class="flex flex-col gap-3 list-none p-0 m-0">
                <li class="text-white/50 text-sm">Foundation (30 min): the four mechanical bases</li>
                <li class="text-white/50 text-sm">Application (45 min): live drilling, camera on, real-time correction</li>
                <li class="text-white/50 text-sm">Integration (15 min): your 30-day written progression</li>
                <li class="text-[#D4A373] text-sm">Full recording delivered within 24 hours</li>
              </ul>
            </div>
          </div>
          <div class="mt-12">
            <!-- TODO: POST-JUNE-27 DATE SWAP -->
            <p class="text-white/25 text-[10px] tracking-widest uppercase mb-5">Limited seats · Saturday, June 27</p>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <span class="text-white font-black text-4xl">$197</span>
              <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
                class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap">
                Reserve Your Seat →
              </a>
            </div>
          </div>
        </div>

        <!-- Right 40%: Context stacked -->
        <div class="flex flex-col gap-[2px]">

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">Who this is for</p>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Fighters whose ambition is ahead of their gym. Competitive amateurs, coaches, and serious athletes who want structural understanding — not more conditioning.</p>
          </div>

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-4">The Composure Guarantee</p>
            <p class="text-[#0A0A0A]/50 text-sm leading-relaxed">Show up, do the work. If you don't walk away with a clear framework, email rainers@theerainers.com within 24 hours. Full refund. No questions.</p>
          </div>

          <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-10 flex-1">
            <p class="text-[#0A0A0A]/20 text-xs leading-relaxed italic mb-4">"I discipline my body and keep it under control."</p>
            <p class="text-[#D4A373] text-[10px] tracking-widest uppercase">1 Corinthians 9:27</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- DEFENSE COVER 1: secondary image + testimonial text -->
  <section class="bg-[#0A0A0A] overflow-hidden">
    <div class="max-w-[1280px] mx-auto grid grid-cols-1 md:grid-cols-[1fr_1fr]">

      <!-- Image: defense_cover1 -->
      <div class="relative overflow-hidden" style="min-height: 480px;">
        <Picture
          src={defenseCover1}
          formats={['avif', 'webp']}
          widths={[600, 900, 1300]}
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="Defense Workshop — live training session with Rainers"
          quality={80}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover object-top"
        />
      </div>

      <!-- Testimonial -->
      <div class="px-8 md:px-16 py-16 md:py-24 flex flex-col justify-center">
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-8">What fighters say</p>
        <p class="font-black text-white uppercase tracking-tighter text-2xl md:text-3xl leading-[0.88] mb-8">
          "The structure that was missing from my entire training."
        </p>
        <p class="text-white/50 text-sm leading-relaxed mb-10 max-w-[400px]">
          Real-time correction on live movement. Not theory — the actual mechanical gaps showing up in sparring, addressed in the session.
        </p>
        <div class="border-t border-white/10 pt-6">
          <p class="text-white/70 text-sm font-bold">Giancarlo</p>
          <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mt-1">Workshop Attendee · Amateur Competitor</p>
        </div>
      </div>

    </div>
  </section>

  <!-- TESTIMONIAL VIDEO -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-20 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full">
      <div class="max-w-[480px] mx-auto aspect-video bg-[#0A0A0A]">
        <iframe
          src="https://www.youtube.com/embed/VCj0Dgfoako"
          title="Giancarlo — Thee Rainers Workshop"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-20 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full">
      <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-12">Questions</p>
      <div class="flex flex-col divide-y divide-[#0A0A0A]/8 max-w-[720px]">
        {faqItems.map((item) => (
          <details class="group py-8 cursor-pointer">
            <summary class="font-bold text-[#0A0A0A]/60 text-sm tracking-wide list-none flex items-center justify-between gap-8 hover:text-[#0A0A0A] transition-colors duration-200">
              {item.question}
              <span class="text-[#D4A373] shrink-0 text-lg leading-none group-open:rotate-45 transition-transform duration-200">+</span>
            </summary>
            <p class="text-[#0A0A0A]/35 text-sm leading-relaxed mt-6">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Not ready? Down-path -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-12 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full flex flex-col sm:flex-row items-center justify-between gap-6">
      <p class="text-[#0A0A0A]/30 text-sm">Not ready for live? Start with the free 30-day protocol first.</p>
      <div class="flex gap-4 shrink-0">
        <a href="/footwork-foundation" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity">Get Free Protocol →</a>
        <a href="/vault" class="text-[#0A0A0A]/30 text-xs font-bold tracking-widest uppercase hover:text-[#0A0A0A]/60 transition-colors">See All Products →</a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white px-8 md:px-16 lg:px-24 py-24 border-t border-[#0A0A0A]/8">
    <div class="max-w-[1280px] mx-auto w-full flex flex-col md:flex-row items-start md:items-end justify-between gap-12">
      <div>
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase mb-4">One session. The mechanics start here.</p>
        <h2 class="font-black text-[#0A0A0A]/55 uppercase tracking-tighter text-3xl md:text-4xl leading-[0.9] max-w-[560px]">"I do not run aimlessly. I do not box as one beating the air."</h2>
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mt-4">1 Corinthians 9:26</p>
      </div>
      <div class="flex flex-col gap-4 shrink-0">
        <a href="https://buy.stripe.com/7sY28r8lt1D06XU6446J20n" target="_blank"
          class="blue-btn inline-flex items-center justify-center font-bold border-2 border-[#0057FF] text-[#0057FF] bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-[#0057FF] hover:text-white whitespace-nowrap">
          Reserve Your Seat — $197 →
        </a>
        <a href="/vault"
          class="inline-flex items-center justify-center font-bold border border-[#0A0A0A]/15 text-[#0A0A0A]/30 bg-transparent px-10 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:border-[#0A0A0A]/30 hover:text-[#0A0A0A]/50 whitespace-nowrap">
          Browse the Vault →
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const el = document.getElementById('workshop-countdown');
  if (el) {
    const target = new Date('2026-06-27T00:00:00').getTime(); // TODO: POST-JUNE-27 DATE SWAP
    const update = () => {
      const days = Math.ceil((target - Date.now()) / 86400000);
      el.textContent = days > 0 ? days + ' days away' : 'Today';
    };
    update();
  }
</script>

---
export const prerender = false;
import Layout from '../layouts/Base.astro';
import { env as cfEnv } from 'cloudflare:workers';

const e = cfEnv as unknown as Record<string, string>;
const communityChat = e['COMMUNITY_CHAT_INVITE'] ?? '';

// Session ID is in the URL from Stripe success redirect
const sessionId = Astro.url.searchParams.get('session_id') ?? '';
---
<Layout title="Welcome to the Greatness Community — Thee Rainers">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="bg-white min-h-screen flex flex-col justify-center px-6 md:px-12 lg:px-20 py-32">
    <div class="max-w-[680px] mx-auto w-full">

      <div class="mb-10 flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-[#22C55E]" aria-hidden="true"></div>
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase">You're In</p>
      </div>

      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter leading-[0.85] mb-8"
        style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Welcome to<br/>Greatness Community.
      </h1>

      <div class="border-l-4 border-[#6A0DAD] pl-6 mb-12">
        <p class="text-[#0A0A0A] text-lg font-bold leading-snug mb-2">Check your inbox.</p>
        <p class="text-[#0A0A0A]/55 text-sm leading-relaxed">
          Your welcome email is on the way to the address you used at checkout.
          It has the community chat invite, the next Proving Ground date and Zoom link, and your Customer Portal link to manage billing. Check spam if you don't see it in a few minutes.
        </p>
      </div>

      <div class="flex flex-col divide-y divide-[#0A0A0A]/8 mb-12">

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
            <div class="w-2 h-2 bg-[#6A0DAD]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">The Proving Ground</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed">Weekly live session. Camera on. Rainers reviews your movement. The date, time, and Zoom link for the next session are in your welcome email.</p>
          </div>
        </div>

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
            <div class="w-2 h-2 bg-[#0057FF]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">Community Chat</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed mb-2">Private space for members. Ask questions between sessions, post clips, walk with brothers doing the same work.</p>
            {communityChat ? (
              <a href={communityChat} target="_blank" rel="noopener noreferrer"
                class="text-[#6A0DAD] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity">
                Join Community Chat →
              </a>
            ) : (
              <p class="text-[#0A0A0A]/30 text-xs">Invite link in your welcome email.</p>
            )}
          </div>
        </div>

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
            <div class="w-2 h-2 bg-[#D4A373]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">Drill Library</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed mb-2">Full access to every drill, organized by lever. Start with whatever is weakest in your game.</p>
            <a href="/library" class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity">Browse Library →</a>
          </div>
        </div>

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
            <div class="w-2 h-2 bg-[#0A0A0A]/20"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">Manage Your Membership</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed mb-2">Update your card, switch plans, or cancel anytime. No forms. No questions. Self-serve through the Customer Portal.</p>
            {sessionId ? (
              <button id="portal-btn"
                class="text-[#0057FF] text-xs font-bold tracking-widest uppercase hover:opacity-60 transition-opacity cursor-pointer bg-transparent border-0 p-0 disabled:opacity-40"
                aria-label="Open Customer Portal to manage your subscription">
                Open Customer Portal →
              </button>
            ) : (
              <p class="text-[#0A0A0A]/30 text-xs">Portal link in your welcome email.</p>
            )}
          </div>
        </div>

      </div>

      <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-6 mb-10">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Start here</p>
        <p class="font-black text-[#0A0A0A] text-base uppercase tracking-tight leading-tight mb-3">
          The Free Foundation Protocol runs alongside everything.
        </p>
        <p class="text-[#0A0A0A]/45 text-xs leading-relaxed mb-5">
          If you haven't run it yet, start today. It sets the structural base the Proving Ground builds on.
        </p>
        <a href="/footwork-foundation"
          class="inline-flex items-center font-bold text-[#0057FF] text-xs tracking-widest uppercase hover:opacity-60 transition-opacity">
          Start the Free Protocol →
        </a>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t border-[#0A0A0A]/8">
        <p class="text-[#0A0A0A]/30 text-xs leading-relaxed">
          Email not arrived after 10 minutes?<br/>
          <a href="mailto:rainers@theerainers.com" class="text-[#0057FF] hover:opacity-60 transition-opacity font-bold">rainers@theerainers.com</a>
        </p>
        <a href="/community/inside"
          class="text-[#6A0DAD] text-xs tracking-widest uppercase font-bold hover:opacity-60 transition-opacity whitespace-nowrap">
          Enter Member Area →
        </a>
      </div>

    </div>
  </section>

</Layout>

{sessionId && (
  <script define:vars={{ sessionId }}>
    const btn = document.getElementById('portal-btn');
    if (btn) {
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        btn.textContent = 'Opening...';
        try {
          const res = await fetch('/api/portal', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ session_id: sessionId }),
          });
          const data = await res.json();
          if (data.url) window.location.href = data.url;
          else { btn.disabled = false; btn.textContent = 'Open Customer Portal →'; }
        } catch {
          btn.disabled = false;
          btn.textContent = 'Open Customer Portal →';
        }
      });
    }
  </script>
)}

---
import Layout from '../layouts/Base.astro';
export const prerender = true;
---
<Layout title="Welcome to the Greatness Community — Thee Rainers">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="bg-white min-h-screen flex flex-col justify-center px-6 md:px-12 lg:px-20 py-32">
    <div class="max-w-[680px] mx-auto w-full">

      <div class="mb-10 flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-[#22C55E]"></div>
        <p class="text-[#D4A373] text-[11px] tracking-widest uppercase">You're In</p>
      </div>

      <h1 class="font-black text-[#0A0A0A] uppercase tracking-tighter leading-[0.85] mb-8"
        style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
        Welcome to<br/>Greatness Community.
      </h1>

      <div class="border-l-4 border-[#6A0DAD] pl-6 mb-12">
        <p class="text-[#0A0A0A] text-lg font-bold leading-snug mb-2">Check your inbox.</p>
        <p class="text-[#0A0A0A]/55 text-sm leading-relaxed">
          Your access link is on the way to the email you used at checkout.
          Arrives within a few minutes. Check spam if you don't see it.
        </p>
      </div>

      <div class="flex flex-col divide-y divide-[#0A0A0A]/8 mb-12">

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5">
            <div class="w-2 h-2 bg-[#6A0DAD]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">The Proving Ground</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed">Monthly live session. Camera on. Real-time correction. The session date, Zoom link, and prep instructions are in your welcome email.</p>
          </div>
        </div>

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5">
            <div class="w-2 h-2 bg-[#0057FF]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">Member Portal</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed">Access your drill library, session archive, and community resources. Your welcome email contains the direct link.</p>
          </div>
        </div>

        <div class="grid grid-cols-[24px_1fr] gap-4 py-5 items-start">
          <div class="w-6 h-6 border border-[#0A0A0A]/15 flex items-center justify-center shrink-0 mt-0.5">
            <div class="w-2 h-2 bg-[#D4A373]"></div>
          </div>
          <div>
            <p class="font-black text-[#0A0A0A] text-sm uppercase tracking-tight mb-0.5">Renewal</p>
            <p class="text-[#0A0A0A]/45 text-xs leading-relaxed">Your membership renews automatically each cycle. Cancel anytime via the link in your email or by contacting us directly.</p>
          </div>
        </div>

      </div>

      <div class="bg-[#F6F6F6] border border-[#0A0A0A]/8 p-6 mb-10">
        <p class="text-[#D4A373] text-[10px] tracking-widest uppercase mb-3">Start here</p>
        <p class="font-black text-[#0A0A0A] text-base uppercase tracking-tight leading-tight mb-3">
          The Free Foundation Protocol runs alongside everything.
        </p>
        <p class="text-[#0A0A0A]/45 text-xs leading-relaxed mb-5">
          If you haven't run it yet, start today. It sets the structural base the Proving Ground builds on.
        </p>
        <a href="/footwork-foundation"
          class="inline-flex items-center font-bold text-[#0057FF] text-xs tracking-widest uppercase hover:opacity-60 transition-opacity">
          Start the Free Protocol →
        </a>
      </div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-8 border-t border-[#0A0A0A]/8">
        <p class="text-[#0A0A0A]/30 text-xs leading-relaxed">
          Email not arrived after 10 minutes?<br/>
          <a href="mailto:rainers@theerainers.com" class="text-[#0057FF] hover:opacity-60 transition-opacity font-bold">rainers@theerainers.com</a>
        </p>
        <a href="/community/inside"
          class="text-[#6A0DAD] text-xs tracking-widest uppercase font-bold hover:opacity-60 transition-opacity whitespace-nowrap">
          Enter Member Area →
        </a>
      </div>

    </div>
  </section>

</Layout>

---
import Base from '../layouts/Base.astro';
import Container from '../components/primitives/Container.astro';
import Section from '../components/primitives/Section.astro';
import Button from '../components/primitives/Button.astro';
---
<Base title="Shop — Thee Rainers" description="Systematized boxing blueprints for the self-coached fighter.">
  <Section class="pt-32 pb-20">
    <Container size="page">
      <h1 class="font-bold text-navy text-5xl mb-4">The Lab.</h1>
      <p class="text-muted text-lg mb-16">Mechanics. Structure. Results. Choose your system.</p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="border border-rule p-8 flex flex-col justify-between bg-cream">
          <h3 class="font-bold text-navy text-xl mb-4">Footwork Blueprint</h3>
          <p class="text-ink mb-8">56 rounds of drills. The base foundation.</p>
          <Button href="https://buy.stripe.com/bJe14n8lt81ogyu3VW6J20k">Buy — $47</Button>
        </div>

        <div class="border-2 border-terracotta p-8 flex flex-col justify-between bg-navy text-white">
          <h3 class="font-bold text-white text-xl mb-4">The Rainers Bundle</h3>
          <p class="mb-8 opacity-90">Footwork + Shadowboxing. Complete OS. Best Value.</p>
          <Button href="https://buy.stripe.com/14A4gz59hgxUaa65006J20m" class="bg-terracotta border-terracotta">Buy Bundle — $87</Button>
        </div>

        <div class="border border-rule p-8 flex flex-col justify-between bg-cream">
          <h3 class="font-bold text-navy text-xl mb-4">Shadowboxing Blueprint</h3>
          <p class="text-ink mb-8">Skill tests, rhythm, and range control.</p>
          <Button href="https://buy.stripe.com/5kQdR91X5dlIeqm8cc6J20l">Buy — $47</Button>
        </div>
      </div>
    </Container>
  </Section>
</Base>
